---
import Layout from '../layouts/Layout.astro';
import Gallery from '../components/Gallery.astro';
import ShaderFigure from '../components/ShaderFigure.astro';
import ConceptDemo from '../components/ConceptDemo.astro';
import CircleDemo from '../components/CircleDemo.astro';
import BirthdayDemo from '../components/BirthdayDemo.astro';
import BellDemo from '../components/BellDemo.astro';
import AmFmDemo from '../components/AmFmDemo.astro';
import PrisonersDemo from '../components/PrisonersDemo.astro';

const ideas = [
  {
    k: 'Everything is a distribution',
    d: 'A number is just a distribution with all its weight on a single point — a Dirac delta. Operators lift over random variables automatically — so X below is random, and Y is random too, with no special syntax. Propagating uncertainty reads exactly like ordinary arithmetic.',
    code: 'X ~ unif(-1, 1)\nY = 2 * X + 3   # Y is a distribution too',
  },
  {
    k: 'The tilde draws; equals transforms',
    d: 'A name bound with ~ is one fixed random draw that every mention reuses — so X − X is exactly 0, never "two samples." Independence comes from separate ~ bindings, exactly like writing X₁, X₂ on paper. No hidden re-draws, no surprises.',
    code: 'A ~ unif_int(1, 6)\nB ~ unif_int(1, 6)   # two independent dice\nA + B                # a genuine 2d6 distribution',
  },
  {
    k: 'Queries: P, E, Var, Q',
    d: 'Nothing is sampled until you ask. A query runs a fast columnar Monte-Carlo pass and reports an honest estimate — the printed digits reflect the standard error, and that error propagates through arithmetic, so 4·P(C) rounds itself correctly.',
    code: 'C = X**2 + Y**2 < 1\n4 * P(C)   # ≈ 3.14',
  },
  {
    k: 'Independence is a shape',
    d: 'Put a shape on the tilde to draw a whole batch at once: ~[n] is an iid vector, ~[n, m] a matrix. A reducer collapses it back to one number — so the birthday paradox over 23 people, all 253 pairwise comparisons, is a single expression.',
    code: 'days ~[23] unif_int(1, 365)\nP(has_duplicate(days))   # ≈ 0.51',
  },
  {
    k: 'if is a value, not a branch',
    d: 'When the condition is random, if c { a } else { b } does not take a path — it builds a new random variable, choosing a or b per sample. That single rule hands you max, min, abs, clamps and payoffs over distributions for free.',
    code: 'higher = if A > B { A } else { B }   # the larger of two dice',
  },
];
---

<Layout>
  <header class="topbar">
    <div class="wide topbar-inner">
      <a class="brand" href="/"><img class="brand-mark" src="/favicon.svg" alt="" width="24" height="24" />noise<span class="brand-tilde">~</span><span class="brand-dim">lang</span></a>
      <nav class="topbar-links">
        <a href="#ideas">How it works</a>
        <a href="#performance">Performance</a>
        <a href="/play">Playground</a>
        <a href="/skill">Skills</a>
        <a href="#author">About</a>
        <a href="https://github.com/manucorporat/noise-lang">GitHub</a>
      </nav>
    </div>
  </header>

  <article class="doc">
    <div class="measure masthead">
      <h1 class="doc-title" data-reveal>The Noise Programming Language</h1>
      <p class="doc-meta" data-reveal style="--reveal-delay: 60ms">
        A static random-variable algebra &amp; forward Monte-Carlo engine. Compiled to WebAssembly,
        runnable in this page.
      </p>
      <div class="abstract" data-reveal style="--reveal-delay: 120ms">
        <p>
          <span class="abstract-label">Abstract.</span>
          In Noise, every value is a probability distribution: a number is the degenerate case, a
          point mass. Operators lift over random variables, the binding <code class="code-inline">~</code>
          draws a fresh sample while <code class="code-inline">=</code> names a transformation, and a
          query such as <code class="code-inline">P(event)</code> estimates a probability by simulation.
          The result is a small language in which propagating uncertainty and running Monte-Carlo
          experiments reads like ordinary mathematics.
        </p>
      </div>
    </div>

    <div class="wide" data-reveal>
      <ShaderFigure n={1} caption="the noise field this language is named for — a fractal-noise surface drawn as ink contours. Move your cursor to disturb it." />
    </div>

    <section id="tour" class="section">
      <div class="measure">
        <h2 class="sec" data-reveal>A visual tour</h2>
        <p data-reveal>
          Short stories, simplest first. We start with the one idea everything else rests on — every
          value is a distribution — then build up. Just scroll: each one walks through its program,
          plays out what the numbers mean, and confirms the answer with the real engine. No buttons.
        </p>
      </div>

      <div class="tour-item"><div class="wide"><ConceptDemo /></div></div>
      <div class="tour-item"><div class="wide"><CircleDemo /></div></div>
      <div class="tour-item"><div class="wide"><BirthdayDemo /></div></div>
      <div class="tour-item"><div class="wide"><BellDemo /></div></div>
      <div class="tour-item"><div class="wide"><AmFmDemo /></div></div>
      <div class="tour-item"><div class="wide"><PrisonersDemo /></div></div>
    </section>

    <section id="examples" class="section">
      <div class="measure">
        <h2 class="sec" data-reveal>Examples</h2>
        <p data-reveal>
          A catalogue of short programs, each a Monte-Carlo experiment with a known closed form, so
          the printed answer can be checked. Open any one in the
          <a href="/play">playground</a> to run and edit it — the real Noise compiler, built to
          WebAssembly and running in your browser. Each program gets its own shareable link.
        </p>
      </div>
      <div class="wide" data-reveal>
        <Gallery />
      </div>
    </section>

    <section id="ideas" class="section">
      <div class="measure">
        <h2 class="sec" data-reveal>How it works</h2>
        <p data-reveal>
          Noise is small by design. Everything above is built from a handful of ideas.
        </p>

        {ideas.map((i) => (
          <div class="subsec-block">
            <h3 class="subsec" data-reveal>{i.k}</h3>
            <p data-reveal>{i.d}</p>
            <pre class="listing" data-reveal><code>{i.code}</code></pre>
          </div>
        ))}
      </div>
    </section>

    <section id="performance" class="section">
      <div class="measure">
        <h2 class="sec" data-reveal>Performance</h2>
        <p data-reveal>
          Almost every Noise program ends in “evaluate this expression over a few million random
          draws.” That loop is compiled, not interpreted. <code class="code-inline">~</code> and the
          distribution constructors build a graph IR that lowers three ways — a portable columnar
          interpreter, a native JIT via <a href="https://cranelift.dev/">Cranelift</a>, and a
          WebAssembly emitter for the browser — all sharing one cost model, so the backend only ever
          changes speed, never results (bit-identical across core counts).
        </p>
        <p data-reveal>
          You write a one-line <code class="code-inline">P(...)</code> and get an expert kernel for
          free. It is built from a stack of techniques, each with its own measured win:
        </p>
        <ul class="perf-techniques" data-reveal>
          <li>
            <b>Kernel fusion</b> — the codegen backends emit one loop that draws its sources, computes
            the whole expression in registers, and stores only the result, erasing the interpreter's
            intermediate memory traffic.
          </li>
          <li>
            <b>Graph simplification</b> — constant folding, finite-safe algebraic identities, and
            common-subexpression elimination shrink the DAG before any code is generated (so
            <code class="code-inline">X + X</code> is one draw, not two).
          </li>
          <li>
            <b>Inlined xoshiro256++ PRNG</b> — the generator is emitted straight into the kernel as a
            handful of shifts/xors/rotates, with zero call overhead on native and in WASM alike.
          </li>
          <li>
            <b>Inlined transcendentals</b> — <code class="code-inline">ln</code>/<code class="code-inline">sin</code>/<code class="code-inline">cos</code>
            (the heart of <code class="code-inline">normal</code>, <code class="code-inline">exp</code>,
            and signals) become straight-line polynomial approximations (~1e-9 vs libm), roughly
            doubling transcendental-bound kernels and skipping a per-draw crossing of the JS boundary
            in the browser.
          </li>
          <li>
            <b>Multi-stream RNG</b> — four independent xoshiro streams run at once to hide the
            generator's serial-dependency latency (the scalar form of SIMD), switched on only where
            the graph is latency-bound.
          </li>
          <li>
            <b>Columnar batches</b> — the interpreter runs 1024 lanes through one instruction at a
            time: a tight, cache-friendly, auto-vectorizing pass over contiguous <code class="code-inline">f64</code>s.
          </li>
          <li>
            <b>Vectorized power-sum reduction</b> — moments accumulate as raw power sums across eight
            unrolled lanes with no per-element divide: ~9.5× faster than a streaming Welford update,
            turning the reduction from the ceiling into a rounding error.
          </li>
          <li>
            <b>Deterministic multicore</b> — sampling fans out with a work-stealing loop whose
            per-chunk accumulators merge as an exactly-associative monoid, so the answer is
            bit-identical regardless of thread count, and reproducible from a seed.
          </li>
          <li>
            <b>Profitability gate</b> — a cost model emits a fused kernel only where it beats the
            vectorized interpreter, so codegen can change the speed but never lose.
          </li>
        </ul>
        <p data-reveal>The payoff, measured on a 14-core M4 Pro:</p>
        <ul class="perf-stats" data-reveal>
          <li>
            <b>~5.8 billion</b> samples/sec (π Monte&nbsp;Carlo, generate + reduce, all cores),
            scaling <b>~9.6×</b> from one core to all of them.
          </li>
          <li>
            Within <b>~1.15×</b> of hand-written, LLVM-compiled Rust per core — and faster end to end,
            because the one-liner fuses and fans out across every core with no flags or annotations.
          </li>
          <li>
            In the browser the emitted WASM kernel runs the same fused loop at <b>~0.5–0.75×</b> of
            native codegen — hundreds of millions of samples/sec, client-side.
          </li>
        </ul>
        <p data-reveal>
          The full write-up, with the benchmark tables behind each number, is in
          <a href="https://github.com/manucorporat/noise-lang/blob/master/PERF.md">PERF.md</a>.
        </p>
      </div>
    </section>

    <section id="author" class="section">
      <div class="measure">
        <h2 class="sec" data-reveal>About the author</h2>

        <div class="author" data-reveal>
          <figure class="author-portrait">
            <picture>
              <source srcset="/manu.webp" type="image/webp" />
              <img
                src="/manu.jpg"
                width="900"
                height="934"
                loading="lazy"
                decoding="async"
                alt="Manu Martínez-Almeida"
              />
            </picture>
            <figcaption>Manu Martínez-Almeida</figcaption>
          </figure>

          <div class="author-body">
            <p class="author-lede">
              <span class="author-name">Manu Mtz.-Almeida.</span>
              Creator of <a href="https://github.com/gin-gonic/gin">Gin</a>, the Go web
              framework, and a core contributor to <a href="https://ionicframework.com/">Ionic</a>
              and <a href="https://stenciljs.com/">Stencil</a>. Principal engineer at
              <a href="https://www.builder.io/">Builder.io</a>, working on compilers,
              high-performance systems, and AI agents.
            </p>
            <p>
              I started Noise nine years ago and never quite finished it. The idea grew out of
              my telecommunications degree — a world of signals, noise, and probability — where
              I kept wishing for a language that could express uncertainty as naturally as it
              expresses arithmetic. This is that wish, picked up again all these years later.
            </p>
            <p class="author-links">
              <a href="https://github.com/manucorporat">github.com/manucorporat</a>
              <span class="author-sep">·</span>
              <a href="https://x.com/manucorporat">x.com/manucorporat</a>
              <span class="author-sep">·</span>
              <a href="https://www.linkedin.com/in/manumartinez-almeida">linkedin</a>
            </p>
          </div>
        </div>
      </div>
    </section>

    <footer class="doc-footer measure">
      <hr />
      <p class="muted" id="footer-version">noise~lang — running on WebAssembly.</p>
    </footer>
  </article>
</Layout>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 30;
    background: rgba(251, 250, 246, 0.88);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--rule);
  }
  .topbar-inner {
    display: flex; align-items: baseline; justify-content: space-between;
    padding-top: 0.7rem; padding-bottom: 0.7rem;
  }
  .brand { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--serif); font-weight: 700; font-size: 1.1rem; color: var(--ink); }
  .brand:hover { text-decoration: none; }
  .brand-mark { display: block; width: 1.4em; height: 1.4em; }
  .brand-dim { color: var(--ink-dim); }
  /* the serif tilde sits high and tiny; typeset it in mono, baseline-aligned, as the draw operator */
  .brand-tilde {
    font-family: var(--mono);
    font-weight: 500;
    color: var(--accent);
    margin: 0 0.04em;
    vertical-align: baseline;
    position: relative;
    top: 0.02em;
  }
  .topbar-links { display: flex; gap: 1.3rem; }
  .topbar-links a { color: var(--ink-dim); font-size: 0.92rem; }
  .topbar-links a:hover { color: var(--ink); text-decoration: none; }
  @media (max-width: 680px) { .topbar-links a:not(:last-child) { display: none; } }

  .doc { counter-reset: section; padding: 2.5rem 0 1rem; }

  .masthead { padding-top: 1.5rem; }
  .doc-title {
    font-size: clamp(2.1rem, 5vw, 3.1rem);
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
  }
  .doc-meta { color: var(--ink-dim); font-size: 1.05rem; margin: 0 0 1.6rem; font-style: italic; }
  .abstract {
    border-left: 2px solid var(--rule);
    padding: 0.1rem 0 0.1rem 1.2rem;
    margin: 0 0 0.5rem;
  }
  .abstract p { margin: 0; font-size: 1.02rem; color: #2c2a24; }
  .abstract-label { font-weight: 700; }

  .section { padding: 2.5rem 0; }

  /* numbered sections + subsections, paper-style */
  .sec {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin: 0 0 0.8rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--rule);
  }
  .tour-item { margin-top: 3.5rem; }
  .tour-item .demo-title { margin-bottom: 0.5rem; }
  .subsec-block { margin-top: 2rem; }
  .subsec { font-size: 1.25rem; margin: 0 0 0.5rem; }

  /* performance: techniques (named) + headline stats (numeric) */
  .perf-techniques { margin: 1.3rem 0; padding-left: 1.1rem; }
  .perf-techniques li { margin: 0.6rem 0; line-height: 1.62; }
  .perf-techniques b { font-weight: 700; color: var(--ink); }

  .perf-stats { margin: 1.3rem 0; padding-left: 1.1rem; }
  .perf-stats li { margin: 0.5rem 0; line-height: 1.6; }
  .perf-stats b { font-family: var(--mono); font-weight: 700; color: var(--accent); }

  /* code listing on the page */
  .listing {
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 1rem 1.2rem;
    margin: 1rem 0 0;
    font-size: 0.92rem;
    line-height: 1.6;
    overflow-x: auto;
    white-space: pre;
    color: #2c2a24;
  }

  .doc-footer { padding-bottom: 3rem; }
  .doc-footer p { font-size: 0.92rem; }

  /* about the author — a journal-style author note, typeset like the end of a paper */
  .author {
    display: flex;
    gap: 1.6rem;
    align-items: flex-start;
    margin-top: 0.6rem;
  }
  .author-portrait {
    flex: 0 0 auto;
    width: 168px;
    margin: 0;
  }
  .author-portrait img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--rule);
    border-radius: 3px;
    background: var(--paper-2);
    /* a faint warm cast so the photo sits in the cream palette rather than on top of it */
    filter: saturate(0.92) contrast(1.02);
  }
  .author-portrait figcaption {
    margin-top: 0.5rem;
    font-size: 0.82rem;
    font-style: italic;
    color: var(--ink-dim);
    text-align: center;
  }
  .author-body { flex: 1 1 auto; min-width: 0; }
  .author-body > p { margin: 0 0 0.85rem; }
  .author-body > p:last-child { margin-bottom: 0; }
  .author-lede { color: #2c2a24; }
  /* small-caps name, the way an author byline is set in a journal */
  .author-name {
    font-weight: 700;
    font-variant: small-caps;
    letter-spacing: 0.02em;
    margin-right: 0.15em;
  }
  .author-links {
    font-size: 0.9rem;
    font-family: var(--mono);
    color: var(--ink-dim);
    padding-top: 0.3rem;
    border-top: 1px solid var(--rule);
  }
  .author-sep { color: var(--ink-faint); margin: 0 0.5em; }

  @media (max-width: 560px) {
    .author { flex-direction: column; gap: 1.1rem; }
    .author-portrait { width: 140px; align-self: flex-start; }
    .author-portrait figcaption { text-align: left; }
  }
</style>

<script>
  import { noiseVersion } from '../lib/noise';
  noiseVersion()
    .then((v) => {
      const el = document.getElementById('footer-version');
      if (el) el.textContent = `noise~lang v${v} — running on WebAssembly.`;
    })
    .catch(() => {});
</script>
