---
import Layout from '../layouts/Layout.astro';
import Playground from '../components/Playground.astro';
import Gallery from '../components/Gallery.astro';
import ShaderFigure from '../components/ShaderFigure.astro';
import CircleDemo from '../components/CircleDemo.astro';
import DiceDemo from '../components/DiceDemo.astro';
import CltDemo from '../components/CltDemo.astro';
import GaltonDemo from '../components/GaltonDemo.astro';
import AmFmDemo from '../components/AmFmDemo.astro';

const ideas = [
  {
    k: 'Everything is a distribution',
    d: 'A number is just a distribution with all its weight on a single point. Operators lift over random variables automatically — so X below is random, and Y is random too, with no special syntax. Propagating uncertainty reads exactly like ordinary arithmetic.',
    code: 'X ~ unif(-1, 1)\nY = 2 * X + 3   # Y is a distribution too',
  },
  {
    k: 'The tilde draws; equals transforms',
    d: 'A name bound with ~ is one fixed random draw that every mention reuses — so X − X is exactly 0, never "two samples." Independence comes from separate ~ bindings, exactly like writing X₁, X₂ on paper. No hidden re-draws, no surprises.',
    code: 'A ~ unif_int(1, 6)\nB ~ unif_int(1, 6)   # two independent dice\nA + B                # a genuine 2d6 distribution',
  },
  {
    k: 'Queries: P, E, Var, Q',
    d: 'Nothing is sampled until you ask. A query runs a fast columnar Monte-Carlo pass and reports an honest estimate — the printed digits reflect the standard error, and that error propagates through arithmetic, so 4·P(C) rounds itself correctly.',
    code: 'C = X**2 + Y**2 < 1\n4 * P(C)   # ≈ 3.14',
  },
];
---

<Layout>
  <header class="topbar">
    <div class="wide topbar-inner">
      <a class="brand" href="/">noise<span class="brand-dim">-lang</span></a>
      <nav class="topbar-links">
        <a href="#tour">Tour</a>
        <a href="#playground-section">Playground</a>
        <a href="#examples">Examples</a>
        <a href="#ideas">How it works</a>
        <a href="https://github.com/">GitHub</a>
      </nav>
    </div>
  </header>

  <article class="doc">
    <div class="measure masthead">
      <h1 class="doc-title" data-reveal>The Noise Programming Language</h1>
      <p class="doc-meta" data-reveal style="--reveal-delay: 60ms">
        A static random-variable algebra &amp; forward Monte-Carlo engine. Compiled to WebAssembly,
        runnable in this page.
      </p>
      <div class="abstract" data-reveal style="--reveal-delay: 120ms">
        <p>
          <span class="abstract-label">Abstract.</span>
          In Noise, every value is a probability distribution: a number is the degenerate case, a
          point mass. Operators lift over random variables, the binding <code class="code-inline">~</code>
          draws a fresh sample while <code class="code-inline">=</code> names a transformation, and a
          query such as <code class="code-inline">P(event)</code> estimates a probability by simulation.
          The result is a small language in which propagating uncertainty and running Monte-Carlo
          experiments reads like ordinary mathematics.
        </p>
      </div>
    </div>

    <div class="wide" data-reveal>
      <ShaderFigure n={1} caption="the noise field this language is named for — a fractal-noise surface drawn as ink contours. Move your cursor to disturb it." />
    </div>

    <section id="tour" class="section">
      <div class="measure">
        <h2 class="sec" data-reveal>A visual tour</h2>
        <p data-reveal>
          Five short stories, simplest first. Just scroll — each one walks through its program, then
          plays out what the numbers mean, and confirms the answer with the real engine. No buttons.
        </p>
      </div>

      <div class="tour-item"><div class="wide"><CircleDemo /></div></div>
      <div class="tour-item"><div class="wide"><DiceDemo /></div></div>
      <div class="tour-item"><div class="wide"><CltDemo /></div></div>
      <div class="tour-item"><div class="wide"><GaltonDemo /></div></div>
      <div class="tour-item"><AmFmDemo /></div>
    </section>

    <section id="playground-section" class="section">
      <div class="measure">
        <h2 class="sec" data-reveal>The playground</h2>
        <p data-reveal>
          Now the full editor — the real Noise compiler, built to WebAssembly. Choose an example from
          the menu or write your own, then press <span class="code-inline">⌘/Ctrl + Enter</span>.
          Programs are shareable — the <em>Share</em> button puts the current program in the URL.
        </p>
      </div>
      <div class="wide playground-host" data-reveal>
        <Playground />
      </div>
    </section>

    <section id="examples" class="section">
      <div class="measure">
        <h2 class="sec" data-reveal>Examples</h2>
        <p data-reveal>
          A catalogue of short programs, each a Monte-Carlo experiment with a known closed form, so
          the printed answer can be checked. Open any one to run and edit it.
        </p>
      </div>
      <div class="wide" data-reveal>
        <Gallery />
      </div>
    </section>

    <section id="ideas" class="section">
      <div class="measure">
        <h2 class="sec" data-reveal>How it works</h2>
        <p data-reveal>
          Noise is small by design. Everything above is built from three ideas.
        </p>

        {ideas.map((i) => (
          <div class="subsec-block">
            <h3 class="subsec" data-reveal>{i.k}</h3>
            <p data-reveal>{i.d}</p>
            <pre class="listing" data-reveal><code>{i.code}</code></pre>
          </div>
        ))}
      </div>
    </section>

    <footer class="doc-footer measure">
      <hr />
      <p class="muted" id="footer-version">noise-lang — running on WebAssembly.</p>
    </footer>
  </article>
</Layout>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 30;
    background: rgba(251, 250, 246, 0.88);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--rule);
  }
  .topbar-inner {
    display: flex; align-items: baseline; justify-content: space-between;
    padding-top: 0.7rem; padding-bottom: 0.7rem;
  }
  .brand { font-family: var(--serif); font-weight: 700; font-size: 1.1rem; color: var(--ink); }
  .brand:hover { text-decoration: none; }
  .brand-dim { color: var(--ink-dim); }
  .topbar-links { display: flex; gap: 1.3rem; }
  .topbar-links a { color: var(--ink-dim); font-size: 0.92rem; }
  .topbar-links a:hover { color: var(--ink); text-decoration: none; }
  @media (max-width: 680px) { .topbar-links a:not(:last-child) { display: none; } }

  .doc { counter-reset: section; padding: 2.5rem 0 1rem; }

  .masthead { padding-top: 1.5rem; }
  .doc-title {
    font-size: clamp(2.1rem, 5vw, 3.1rem);
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
  }
  .doc-meta { color: var(--ink-dim); font-size: 1.05rem; margin: 0 0 1.6rem; font-style: italic; }
  .abstract {
    border-left: 2px solid var(--rule);
    padding: 0.1rem 0 0.1rem 1.2rem;
    margin: 0 0 0.5rem;
  }
  .abstract p { margin: 0; font-size: 1.02rem; color: #2c2a24; }
  .abstract-label { font-weight: 700; }

  .section { padding: 2.5rem 0; }

  /* numbered sections + subsections, paper-style */
  .sec {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin: 0 0 0.8rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--rule);
  }
  .tour-item { margin-top: 3.5rem; }
  .tour-item .demo-title { margin-bottom: 0.5rem; }
  .subsec-block { margin-top: 2rem; }
  .subsec { font-size: 1.25rem; margin: 0 0 0.5rem; }

  .playground-host { margin-top: 1.5rem; }

  /* code listing on the page */
  .listing {
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 1rem 1.2rem;
    margin: 1rem 0 0;
    font-size: 0.92rem;
    line-height: 1.6;
    overflow-x: auto;
    white-space: pre;
    color: #2c2a24;
  }

  .doc-footer { padding-bottom: 3rem; }
  .doc-footer p { font-size: 0.92rem; }
</style>

<script>
  import { noiseVersion } from '../lib/noise';
  noiseVersion()
    .then((v) => {
      const el = document.getElementById('footer-version');
      if (el) el.textContent = `noise-lang v${v} — running on WebAssembly.`;
    })
    .catch(() => {});
</script>
