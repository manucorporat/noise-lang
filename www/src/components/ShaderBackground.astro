---
// A full-viewport WebGL background: animated fractal noise (fbm) with domain warping, in the
// site's cool indigo/teal/magenta palette. Fixed behind all content, non-interactive, and it
// respects `prefers-reduced-motion` (freezes to a static field). Inspired by the language's name.
---

<canvas id="noise-bg" aria-hidden="true"></canvas>

<style>
  #noise-bg {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: -2;
    display: block;
    background: #07090f;
  }
  /* A soft vignette + dark wash so foreground text stays readable over the shader. */
  #noise-bg + .bg-veil,
  .bg-veil {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(120% 80% at 50% 0%, transparent 0%, rgba(7, 9, 15, 0.35) 55%, rgba(7, 9, 15, 0.8) 100%),
      linear-gradient(180deg, rgba(7, 9, 15, 0.2) 0%, rgba(7, 9, 15, 0.55) 100%);
  }
</style>

<div class="bg-veil"></div>

<script>
  const canvas = document.getElementById('noise-bg') as HTMLCanvasElement | null;
  if (canvas) {
    const gl = canvas.getContext('webgl', { antialias: false, alpha: false });
    if (gl) {
      const vert = `
        attribute vec2 p;
        void main() { gl_Position = vec4(p, 0.0, 1.0); }
      `;

      // Simplex noise (Ashima/webgl-noise, 3D) + fbm + two-level domain warp, mapped to a
      // dark cool palette with occasional warm "ember" highlights.
      const frag = `
        precision highp float;
        uniform vec2  u_res;
        uniform float u_time;
        uniform vec2  u_mouse;   // cursor position in uv space (smoothed)

        vec4 permute(vec4 x){ return mod(((x*34.0)+1.0)*x, 289.0); }
        vec4 taylorInvSqrt(vec4 r){ return 1.79284291400159 - 0.85373472095314 * r; }

        float snoise(vec3 v){
          const vec2  C = vec2(1.0/6.0, 1.0/3.0);
          const vec4  D = vec4(0.0, 0.5, 1.0, 2.0);
          vec3 i  = floor(v + dot(v, C.yyy));
          vec3 x0 = v - i + dot(i, C.xxx);
          vec3 g = step(x0.yzx, x0.xyz);
          vec3 l = 1.0 - g;
          vec3 i1 = min(g.xyz, l.zxy);
          vec3 i2 = max(g.xyz, l.zxy);
          vec3 x1 = x0 - i1 + 1.0 * C.xxx;
          vec3 x2 = x0 - i2 + 2.0 * C.xxx;
          vec3 x3 = x0 - 1.0 + 3.0 * C.xxx;
          i = mod(i, 289.0);
          vec4 pp = permute(permute(permute(
                     i.z + vec4(0.0, i1.z, i2.z, 1.0))
                   + i.y + vec4(0.0, i1.y, i2.y, 1.0))
                   + i.x + vec4(0.0, i1.x, i2.x, 1.0));
          float n_ = 1.0/7.0;
          vec3 ns = n_ * D.wyz - D.xzx;
          vec4 j = pp - 49.0 * floor(pp * ns.z * ns.z);
          vec4 x_ = floor(j * ns.z);
          vec4 y_ = floor(j - 7.0 * x_);
          vec4 x = x_ * ns.x + ns.yyyy;
          vec4 y = y_ * ns.x + ns.yyyy;
          vec4 h = 1.0 - abs(x) - abs(y);
          vec4 b0 = vec4(x.xy, y.xy);
          vec4 b1 = vec4(x.zw, y.zw);
          vec4 s0 = floor(b0) * 2.0 + 1.0;
          vec4 s1 = floor(b1) * 2.0 + 1.0;
          vec4 sh = -step(h, vec4(0.0));
          vec4 a0 = b0.xzyw + s0.xzyw * sh.xxyy;
          vec4 a1 = b1.xzyw + s1.xzyw * sh.zzww;
          vec3 p0 = vec3(a0.xy, h.x);
          vec3 p1 = vec3(a0.zw, h.y);
          vec3 p2 = vec3(a1.xy, h.z);
          vec3 p3 = vec3(a1.zw, h.w);
          vec4 norm = taylorInvSqrt(vec4(dot(p0,p0), dot(p1,p1), dot(p2,p2), dot(p3,p3)));
          p0 *= norm.x; p1 *= norm.y; p2 *= norm.z; p3 *= norm.w;
          vec4 m = max(0.6 - vec4(dot(x0,x0), dot(x1,x1), dot(x2,x2), dot(x3,x3)), 0.0);
          m = m * m;
          return 42.0 * dot(m * m, vec4(dot(p0,x0), dot(p1,x1), dot(p2,x2), dot(p3,x3)));
        }

        float fbm(vec3 p){
          float f = 0.0, a = 0.5;
          for (int i = 0; i < 5; i++) {
            f += a * snoise(p);
            p *= 2.02;
            a *= 0.5;
          }
          return f;
        }

        void main(){
          vec2 uv = (gl_FragCoord.xy - 0.5 * u_res) / u_res.y;
          float t = u_time * 0.045;

          // cursor influence: a soft falloff around the pointer that bends the flow toward it
          vec2 toM = uv - u_mouse;
          float md = dot(toM, toM);
          float infl = exp(-md * 2.2);

          // domain warp: noise pushing the lookup coordinates around for a flowing, organic feel
          vec3 q = vec3(uv * 1.6, t);
          vec2 warp = vec2(fbm(q), fbm(q + vec3(5.2, 1.3, 0.0)));
          // the cursor swirls the field: rotate the pull near the pointer for a vortex feel
          vec2 swirl = vec2(-toM.y, toM.x);
          vec3 r = vec3(uv * 1.6 + 0.9 * warp + (swirl * 1.2 - toM * 0.6) * infl, t * 1.3);
          float n = fbm(r);
          float n2 = fbm(r * 2.1 + vec3(warp.yx * 1.5, 0.0));

          float v = 0.5 + 0.5 * n;

          // palette: deep navy -> indigo -> teal, with a faint magenta/amber ember in the ridges
          vec3 deep   = vec3(0.035, 0.05, 0.10);
          vec3 indigo = vec3(0.12, 0.13, 0.32);
          vec3 teal   = vec3(0.10, 0.42, 0.46);
          vec3 ember  = vec3(0.78, 0.36, 0.52);

          vec3 col = mix(deep, indigo, smoothstep(0.2, 0.7, v));
          col = mix(col, teal, smoothstep(0.55, 0.95, v) * 0.6);
          float ridge = pow(smoothstep(0.6, 1.0, abs(n2)), 3.0);
          col += ember * ridge * 0.35;

          // a cool glow trailing the cursor
          col += mix(teal, ember, 0.4) * infl * 0.28;

          // subtle radial darkening toward the edges
          col *= 1.0 - 0.35 * dot(uv, uv);

          // a touch of animated film grain to keep gradients from banding
          float grain = fract(sin(dot(gl_FragCoord.xy, vec2(12.9898, 78.233)) + u_time) * 43758.5453);
          col += (grain - 0.5) * 0.025;

          gl_FragColor = vec4(col, 1.0);
        }
      `;

      const compile = (type: number, src: string) => {
        const s = gl.createShader(type)!;
        gl.shaderSource(s, src);
        gl.compileShader(s);
        if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
          console.error('noise-bg shader error:', gl.getShaderInfoLog(s));
        }
        return s;
      };

      const prog = gl.createProgram()!;
      gl.attachShader(prog, compile(gl.VERTEX_SHADER, vert));
      gl.attachShader(prog, compile(gl.FRAGMENT_SHADER, frag));
      gl.linkProgram(prog);
      gl.useProgram(prog);

      // full-screen triangle
      const buf = gl.createBuffer();
      gl.bindBuffer(gl.ARRAY_BUFFER, buf);
      gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);
      const loc = gl.getAttribLocation(prog, 'p');
      gl.enableVertexAttribArray(loc);
      gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);

      const uRes = gl.getUniformLocation(prog, 'u_res');
      const uTime = gl.getUniformLocation(prog, 'u_time');
      const uMouse = gl.getUniformLocation(prog, 'u_mouse');

      const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
      let cw = 1;
      let ch = 1;
      const resize = () => {
        const w = Math.floor(window.innerWidth * dpr);
        const h = Math.floor(window.innerHeight * dpr);
        cw = w;
        ch = h;
        canvas.width = w;
        canvas.height = h;
        gl.viewport(0, 0, w, h);
        gl.uniform2f(uRes, w, h);
      };
      window.addEventListener('resize', resize);
      resize();

      // Mouse tracking: `target` is the latest cursor (in the shader's uv space), `mouse` eases
      // toward it each frame so the glow trails smoothly instead of snapping.
      const target = { x: 0, y: 0 };
      const mouse = { x: 0, y: 0 };
      const toUv = (clientX: number, clientY: number) => {
        // match gl_FragCoord: x scales by dpr, y is flipped; both normalized by height.
        target.x = (clientX * dpr - 0.5 * cw) / ch;
        target.y = (0.5 * ch - clientY * dpr) / ch;
      };
      window.addEventListener('pointermove', (e) => toUv(e.clientX, e.clientY), { passive: true });

      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const start = performance.now();
      let raf = 0;
      const render = (now: number) => {
        const t = reduce ? 12.0 : (now - start) / 1000;
        // ease the smoothed cursor toward the latest target
        mouse.x += (target.x - mouse.x) * 0.06;
        mouse.y += (target.y - mouse.y) * 0.06;
        gl.uniform2f(uMouse, mouse.x, mouse.y);
        gl.uniform1f(uTime, t);
        gl.drawArrays(gl.TRIANGLES, 0, 3);
        if (!reduce) raf = requestAnimationFrame(render);
      };
      // Pause when the tab is hidden to save the GPU.
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          cancelAnimationFrame(raf);
        } else if (!reduce) {
          raf = requestAnimationFrame(render);
        }
      });
      render(start);
    }
  }
</script>
