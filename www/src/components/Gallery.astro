---
import { examplesByCategory } from '../data/examples';
const groups = examplesByCategory();
---

<section id="examples" class="section">
  <div class="section-head" data-reveal>
    <p class="eyebrow">Examples</p>
    <h2>Learn by example</h2>
    <p>Every card is a real Monte Carlo experiment with a known answer. Open one to run, tweak, and share it.</p>
  </div>

  <div class="container">
    {groups.map((group) => (
      <div class="cat">
        <h3 class="cat-title" data-reveal>{group.category}</h3>
        <div class="gallery" data-reveal-group data-reveal-step="50">
          {group.items.map((ex) => (
            <article class="card glass" data-id={ex.id} data-reveal="scale">
              <header class="card-head">
                <h4>{ex.title}</h4>
                {ex.analytic && <span class="card-analytic">{ex.analytic}</span>}
              </header>
              <p class="card-blurb">{ex.blurb}</p>
              <button class="card-open" data-id={ex.id} type="button">Open in playground →</button>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .cat { margin-bottom: 2.5rem; }
  .cat-title {
    margin: 0 0 1rem;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-2);
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.5rem;
  }
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .card {
    padding: 1.1rem 1.2rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .card:hover { transform: translateY(-3px); border-color: var(--accent-2); }
  .card-head { display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem; }
  .card-head h4 { margin: 0; font-size: 1.05rem; }
  .card-analytic {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--amber);
    white-space: nowrap;
  }
  .card-blurb { margin: 0; color: var(--text-dim); font-size: 0.92rem; flex: 1; }
  .card-open {
    align-self: flex-start;
    margin-top: 0.3rem;
    background: none;
    border: none;
    color: var(--accent-2);
    font: inherit;
    font-size: 0.9rem;
    cursor: pointer;
    padding: 0;
  }
  .card-open:hover { text-decoration: underline; }
</style>

<script>
  // Clicking a card (or its button) loads that example into the playground.
  for (const el of document.querySelectorAll<HTMLElement>('.card[data-id], .card-open[data-id]')) {
    el.addEventListener('click', (e) => {
      const id = (e.currentTarget as HTMLElement).dataset.id;
      if (id) window.dispatchEvent(new CustomEvent('noise:load-example', { detail: id }));
    });
  }
</script>
