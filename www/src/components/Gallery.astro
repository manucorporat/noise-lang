---
import { examplesByCategory } from '../data/examples';
const groups = examplesByCategory();
---

<div class="cat-list">
  {groups.map((group) => (
    <div class="cat">
      <h4 class="cat-title" data-reveal>{group.category}</h4>
      <div class="gallery" data-reveal-group data-reveal-step="45">
        {group.items.map((ex) => (
          <article class="card glass" data-id={ex.id} data-reveal>
            <header class="card-head">
              <h5>{ex.title}</h5>
              {ex.analytic && <span class="card-analytic">{ex.analytic}</span>}
            </header>
            <p class="card-blurb">{ex.blurb}</p>
            <button class="card-open" data-id={ex.id} type="button">Open in playground →</button>
          </article>
        ))}
      </div>
    </div>
  ))}
</div>

<style>
  .cat-list { margin-top: 1.5rem; }
  .cat { margin-bottom: 2.25rem; }
  .cat-title {
    margin: 0 0 0.9rem;
    font-size: 0.85rem;
    font-variant: small-caps;
    letter-spacing: 0.08em;
    color: var(--accent);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 0.4rem;
  }
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(255px, 1fr));
    gap: 0.9rem;
  }
  .card {
    padding: 0.95rem 1.05rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .card:hover { border-color: var(--accent); box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06); }
  .card-head { display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem; }
  .card-head h5 { margin: 0; font-size: 1.02rem; font-weight: 700; }
  .card-analytic {
    font-family: var(--mono);
    font-size: 0.76rem;
    color: var(--accent);
    white-space: nowrap;
  }
  .card-blurb { margin: 0; color: var(--ink-dim); font-size: 0.9rem; flex: 1; line-height: 1.45; }
  .card-open {
    align-self: flex-start;
    margin-top: 0.2rem;
    background: none;
    border: none;
    color: var(--link);
    font: inherit;
    font-size: 0.88rem;
    cursor: pointer;
    padding: 0;
  }
  .card-open:hover { text-decoration: underline; }
</style>

<script>
  for (const el of document.querySelectorAll<HTMLElement>('.card[data-id], .card-open[data-id]')) {
    el.addEventListener('click', (e) => {
      const id = (e.currentTarget as HTMLElement).dataset.id;
      if (id) window.dispatchEvent(new CustomEvent('noise:load-example', { detail: id }));
    });
  }
</script>
