---
// A Galton board, scroll-driven. The code comes first (each peg is a fair Bernoulli step); then the
// balls cascade automatically and pile into the Binomial bell. No buttons.
import CodePanel from './CodePanel.astro';

const code = `use rand; use vec;

# 12 independent left/right bounces; how many go right?
rights = count(iid(bernoulli(0.5), 12))

P(rights == 6)     # the centre bin -> ~0.226`;
---

<div class="scrolly galton-demo">
  <div class="scrolly-grid">
    <div class="scrolly-stage">
      <div class="stage-inner glass">
        <h4 class="stage-title">The Galton board</h4>
        <div class="stage-canvas galton-canvas"><canvas id="galton-canvas" aria-label="A Galton board of balls falling through pegs"></canvas></div>
        <CodePanel filename="galton.noise" code={code} class="galton-code" />
        <div class="stage-foot">
          <span class="stat">balls <b id="galton-n">0</b></span>
          <span class="stat key">P(centre) ≈ <b id="galton-p">—</b></span>
        </div>
        <p class="stage-engine" id="galton-engine"></p>
      </div>
    </div>
    <div class="scrolly-steps" id="galton-steps">
      <div class="scrolly-step" data-step="0">
        <h4>Each peg is a coin flip</h4>
        <p>A ball meets twelve pegs; at each it goes left or right with equal chance. <code class="code-inline">iid(bernoulli(0.5), 12)</code> is those twelve flips; <code class="code-inline">count</code> tallies how many went right.</p>
      </div>
      <div class="scrolly-step" data-step="1">
        <h4>Where does it land?</h4>
        <p>The number of rights is the bin. <code class="code-inline">P(rights == 6)</code> asks how often a ball ends dead centre — a sum of twelve fair steps landing exactly halfway.</p>
      </div>
      <div class="scrolly-step" data-step="2">
        <h4>Drop the balls</h4>
        <p>Watch them cascade. Any single ball's path is unpredictable, yet the bins fill in a strikingly regular shape.</p>
      </div>
      <div class="scrolly-step" data-step="3">
        <h4>A bell, from coin flips</h4>
        <p>The stacks trace the Binomial — a sum of Bernoulli steps — which the central limit theorem rounds into the same bell you just saw. Same law, a different machine.</p>
      </div>
    </div>
  </div>
  <figcaption class="figure-caption"><span class="fig-n">Figure 5.</span> a Galton board: order out of twelve coin flips.</figcaption>
</div>

<style>
  .galton-canvas { height: 250px; }
  .galton-code { font-size: 0.8rem; }
</style>

<script>
  import { runNoise } from '../lib/noise';

  const root = document.querySelector('.galton-demo') as HTMLElement | null;
  const canvas = document.getElementById('galton-canvas') as HTMLCanvasElement | null;
  if (root && canvas) {
    const gl = canvas.getContext('webgl', { antialias: true, alpha: false });
    const nEl = document.getElementById('galton-n')!, pEl = document.getElementById('galton-p')!, engineEl = document.getElementById('galton-engine')!;
    const codeBody = root.querySelector('.code-body') as HTMLElement | null;
    const lines = codeBody ? Array.from(codeBody.querySelectorAll<HTMLElement>('.cl')) : [];
    if (codeBody) codeBody.classList.add('progressive');
    const STEPS = [
      { show: 3, add: [3], run: false },
      { show: 5, add: [5], run: false },
      { show: 5, add: [], run: true },
      { show: 5, add: [], run: true },
    ];
    let engineDone = false, stepRun = false;
    function setStep(i: number) {
      const c = STEPS[i]; stepRun = c.run;
      lines.forEach((el, k) => { el.classList.toggle('shown', k <= c.show); el.classList.toggle('added', c.add.includes(k)); });
      for (const el of root!.querySelectorAll('.scrolly-step')) el.classList.toggle('active', Number((el as HTMLElement).dataset.step) === i);
      if (i === STEPS.length - 1 && !engineDone) { engineDone = true; engineResult(); }
    }

    if (gl) {
      const ROWS = 12, BINS = ROWS + 1, MAX = 360, SPAWN = 2;
      const SP = 1.5 / ROWS, Y_TOP = 0.92, DY = 0.066, Y_PEGBOT = Y_TOP - ROWS * DY, Y_BOT = -0.92, Y_STACKTOP = Y_PEGBOT - 0.04;
      const ptV = `attribute vec2 p; uniform float u_size; void main(){ gl_Position=vec4(p,0.0,1.0); gl_PointSize=u_size; }`;
      const ptF = `precision highp float; uniform vec3 u_col; void main(){ vec2 d=gl_PointCoord-0.5; if(dot(d,d)>0.25) discard; gl_FragColor=vec4(u_col,1.0); }`;
      const trV = `attribute vec2 p; void main(){ gl_Position=vec4(p,0.0,1.0); }`;
      const trF = `precision highp float; uniform vec3 u_col; void main(){ gl_FragColor=vec4(u_col,1.0); }`;
      const sh = (t: number, s: string) => { const x = gl.createShader(t)!; gl.shaderSource(x, s); gl.compileShader(x); return x; };
      const mk = (v: string, f: string) => { const p = gl.createProgram()!; gl.attachShader(p, sh(gl.VERTEX_SHADER, v)); gl.attachShader(p, sh(gl.FRAGMENT_SHADER, f)); gl.linkProgram(p); return p; };
      const ptP = mk(ptV, ptF), trP = mk(trV, trF), ptBuf = gl.createBuffer(), trBuf = gl.createBuffer();
      const pegs: number[] = [];
      for (let r = 0; r < ROWS; r++) { const y = Y_TOP - (r + 0.5) * DY; for (let i = 0; i <= r; i++) pegs.push((i - r / 2) * SP, y); }
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const resize = () => { const r = canvas.getBoundingClientRect(); canvas.width = Math.floor(r.width * dpr); canvas.height = Math.floor(r.height * dpr); gl.viewport(0, 0, canvas.width, canvas.height); draw(); };
      new ResizeObserver(resize).observe(canvas);
      interface Ball { xs: number[]; row: number; bin: number; }
      let balls: Ball[] = []; const counts = new Array(BINS).fill(0); let dropped = 0, frame = 0, raf = 0, inView = false;
      function spawn() { const xs = [0]; let x = 0, rights = 0; for (let r = 0; r < ROWS; r++) { const right = Math.random() < 0.5; x += (right ? 0.5 : -0.5) * SP; if (right) rights++; xs.push(x); } balls.push({ xs, row: 0, bin: rights }); }
      function dPts(v: number[], size: number, c: number[]) { if (!v.length) return; gl.useProgram(ptP); gl.bindBuffer(gl.ARRAY_BUFFER, ptBuf); gl.bufferData(gl.ARRAY_BUFFER, new Float32Array(v), gl.DYNAMIC_DRAW); const a = gl.getAttribLocation(ptP, 'p'); gl.enableVertexAttribArray(a); gl.vertexAttribPointer(a, 2, gl.FLOAT, false, 0, 0); gl.uniform1f(gl.getUniformLocation(ptP, 'u_size'), size * dpr); gl.uniform3f(gl.getUniformLocation(ptP, 'u_col'), c[0], c[1], c[2]); gl.drawArrays(gl.POINTS, 0, v.length / 2); }
      function dTris(v: number[], c: number[]) { if (!v.length) return; gl.useProgram(trP); gl.bindBuffer(gl.ARRAY_BUFFER, trBuf); gl.bufferData(gl.ARRAY_BUFFER, new Float32Array(v), gl.DYNAMIC_DRAW); const a = gl.getAttribLocation(trP, 'p'); gl.enableVertexAttribArray(a); gl.vertexAttribPointer(a, 2, gl.FLOAT, false, 0, 0); gl.uniform3f(gl.getUniformLocation(trP, 'u_col'), c[0], c[1], c[2]); gl.drawArrays(gl.TRIANGLES, 0, v.length / 2); }
      const rect = (x0: number, y0: number, x1: number, y1: number) => [x0, y0, x1, y0, x1, y1, x0, y0, x1, y1, x0, y1];
      function draw() {
        gl.clearColor(0.957, 0.945, 0.91, 1); gl.clear(gl.COLOR_BUFFER_BIT);
        const maxC = Math.max(1, ...counts), bw = 1.7 / BINS, bars: number[] = [];
        for (let b = 0; b < BINS; b++) { const cx = (b - ROWS / 2) * SP, h = (counts[b] / maxC) * (Y_STACKTOP - Y_BOT); bars.push(...rect(cx - bw * 0.42, Y_BOT, cx + bw * 0.42, Y_BOT + h)); }
        dTris(bars, [0.12, 0.43, 0.55]);
        dPts(pegs, 3.0, [0.55, 0.52, 0.47]);
        const bv: number[] = [];
        for (const ball of balls) { const k = Math.floor(ball.row), frac = ball.row - k, x0 = ball.xs[Math.min(k, ROWS)], x1 = ball.xs[Math.min(k + 1, ROWS)]; bv.push(x0 + (x1 - x0) * frac, Y_TOP - ball.row * DY); }
        dPts(bv, 6.5, [0.54, 0.18, 0.29]);
      }
      function loop() {
        frame++;
        if (inView && stepRun) {
          if (dropped < MAX && frame % SPAWN === 0) { spawn(); dropped++; }
          for (const ball of balls) ball.row += 0.22;
          for (const b of balls.filter((b) => b.row >= ROWS)) counts[b.bin]++;
          balls = balls.filter((b) => b.row < ROWS);
          draw();
          const tot = counts.reduce((a, b) => a + b, 0);
          nEl.textContent = String(dropped); pEl.textContent = tot ? (counts[6] / tot).toFixed(4) : '—';
        }
        raf = requestAnimationFrame(loop);
      }
      new IntersectionObserver((es) => { for (const e of es) inView = e.isIntersecting; }, { threshold: 0.2 }).observe(canvas);
      resize(); draw(); raf = requestAnimationFrame(loop);
    }

    async function engineResult() {
      engineEl.textContent = 'engine (10⁶ samples)…';
      try { const r = await runNoise('use rand; use vec; rights = count(iid(bernoulli(0.5), 12)); P(rights == 6)'); engineEl.innerHTML = `engine, 10⁶ samples: <span class="ok">${r.value ?? r.output.trim()}</span> (exact: 0.2256)`; } catch { engineEl.textContent = ''; }
    }

    const io = new IntersectionObserver((es) => { for (const e of es) if (e.isIntersecting && e.intersectionRatio > 0.5) setStep(Number((e.target as HTMLElement).dataset.step)); }, { threshold: [0.5], rootMargin: '-18% 0px -18% 0px' });
    for (const el of root.querySelectorAll('.scrolly-step')) io.observe(el);
    setStep(0);
  }
</script>
