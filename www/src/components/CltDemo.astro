---
// The central limit theorem, scroll-driven: scrolling raises N (the number of uniforms summed),
// so the histogram morphs flat → triangle → bell under your scroll, with the true Normal overlaid.
import CodePanel from './CodePanel.astro';

const code = `use rand; use vec;

# sum of N independent uniforms, standardized
clt = sum(iid(unif(0, 1), 12)) - 6

P(clt > 1)        # ~ 0.159, matching Normal(0,1)`;
---

<div class="scrolly clt-demo">
  <div class="scrolly-grid">
    <div class="scrolly-stage">
      <div class="stage-inner glass">
        <h4 class="stage-title">The central limit theorem</h4>
        <div class="stage-canvas clt-canvas"><canvas id="clt-canvas" aria-label="A sum of uniforms approaching a bell curve"></canvas></div>
        <p class="clt-legend"><span class="sw bar"></span> sampled sum &nbsp; <span class="sw line"></span> Normal(N/2, N/12)</p>
        <CodePanel filename="clt.noise" code={code} class="clt-code" />
        <div class="stage-foot">
          <span class="stat key">N = <b id="clt-n">1</b></span>
          <span class="stat">shape <b id="clt-shape">flat</b></span>
        </div>
        <p class="stage-engine" id="clt-engine"></p>
      </div>
    </div>
    <div class="scrolly-steps" id="clt-steps">
      <div class="scrolly-step" data-step="0">
        <h4>One uniform is flat</h4>
        <p><code class="code-inline">unif(0, 1)</code> is equally likely anywhere in [0, 1] — its histogram is a flat slab. Nothing bell-shaped yet.</p>
      </div>
      <div class="scrolly-step" data-step="1">
        <h4>Two make a triangle</h4>
        <p>Add a second independent uniform with <code class="code-inline">iid(unif(0,1), N)</code> and <code class="code-inline">sum</code>. Middling totals are more likely than extremes — a triangle appears.</p>
      </div>
      <div class="scrolly-step" data-step="2">
        <h4>A few, and it rounds</h4>
        <p>By four terms the corners are already softening into a curve. The parts are still flat uniforms — the <em>sum</em> is what changes shape.</p>
      </div>
      <div class="scrolly-step" data-step="3">
        <h4>Twelve is a bell</h4>
        <p>The histogram now hugs the true Normal (red). That's the central limit theorem: sums drift toward a Normal regardless of the parts — which is why the bell is everywhere.</p>
      </div>
    </div>
  </div>
  <figcaption class="figure-caption"><span class="fig-n">Figure 4.</span> the central limit theorem, driven by your scroll.</figcaption>
</div>

<style>
  .clt-canvas { height: 198px; }
  .clt-legend { font-size: 0.76rem; color: var(--ink-dim); margin: -0.3rem 0 0; display: flex; align-items: center; gap: 0.3rem; }
  .clt-legend .sw { display: inline-block; width: 14px; height: 9px; }
  .clt-legend .sw.bar { background: #1f6f8b; }
  .clt-legend .sw.line { height: 0; border-top: 2px solid #8a2d4a; }
  .clt-code { font-size: 0.82rem; }
</style>

<script>
  import { runNoise } from '../lib/noise';

  const root = document.querySelector('.clt-demo') as HTMLElement | null;
  const canvas = document.getElementById('clt-canvas') as HTMLCanvasElement | null;
  if (root && canvas) {
    const gl = canvas.getContext('webgl', { antialias: true, alpha: false });
    const nEl = document.getElementById('clt-n')!, shapeEl = document.getElementById('clt-shape')!, engineEl = document.getElementById('clt-engine')!;
    const codeBody = root.querySelector('.code-body') as HTMLElement | null;
    const lines = codeBody ? Array.from(codeBody.querySelectorAll<HTMLElement>('.cl')) : [];
    if (codeBody) codeBody.classList.add('progressive');
    const STEPN = [1, 2, 4, 12];
    const STEPS = [{ show: 3, add: [3] }, { show: 3, add: [] }, { show: 3, add: [] }, { show: 5, add: [5] }];

    let engineDone = false;
    let setN = (_n: number) => {};
    function setStep(i: number) {
      const c = STEPS[i];
      lines.forEach((el, k) => { el.classList.toggle('shown', k <= c.show); el.classList.toggle('added', c.add.includes(k)); });
      for (const el of root!.querySelectorAll('.scrolly-step')) el.classList.toggle('active', Number((el as HTMLElement).dataset.step) === i);
      setN(STEPN[i]);
      if (i === STEPS.length - 1 && !engineDone) { engineDone = true; engineResult(); }
    }

    if (gl) {
      const SAMPLES = 24000, BINS = 41, BASE = -0.82, TOP = 0.9;
      const vS = `attribute vec2 p; void main(){ gl_Position=vec4(p,0.0,1.0); }`;
      const fS = `precision highp float; uniform vec3 u_c; void main(){ gl_FragColor=vec4(u_c,1.0); }`;
      const sh = (t: number, s: string) => { const x = gl.createShader(t)!; gl.shaderSource(x, s); gl.compileShader(x); return x; };
      const prog = gl.createProgram()!; gl.attachShader(prog, sh(gl.VERTEX_SHADER, vS)); gl.attachShader(prog, sh(gl.FRAGMENT_SHADER, fS)); gl.linkProgram(prog); gl.useProgram(prog);
      const buf = gl.createBuffer(), uC = gl.getUniformLocation(prog, 'u_c'), aP = gl.getAttribLocation(prog, 'p');
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const resize = () => { const r = canvas.getBoundingClientRect(); canvas.width = Math.floor(r.width * dpr); canvas.height = Math.floor(r.height * dpr); gl.viewport(0, 0, canvas.width, canvas.height); draw(); };
      new ResizeObserver(resize).observe(canvas);
      let density = new Array(BINS).fill(0), curve: number[] = [], peak = 1, N = 1;
      const rect = (x0: number, y0: number, x1: number, y1: number) => [x0, y0, x1, y0, x1, y1, x0, y0, x1, y1, x0, y1];
      function drawTris(v: number[], c: number[]) { gl.bindBuffer(gl.ARRAY_BUFFER, buf); gl.bufferData(gl.ARRAY_BUFFER, new Float32Array(v), gl.DYNAMIC_DRAW); gl.enableVertexAttribArray(aP); gl.vertexAttribPointer(aP, 2, gl.FLOAT, false, 0, 0); gl.uniform3f(uC, c[0], c[1], c[2]); gl.drawArrays(gl.TRIANGLES, 0, v.length / 2); }
      function sampleN(n: number) {
        const counts = new Array(BINS).fill(0), binW = n / BINS;
        for (let s = 0; s < SAMPLES; s++) { let sum = 0; for (let i = 0; i < n; i++) sum += Math.random(); let b = Math.floor((sum / n) * BINS); if (b < 0) b = 0; if (b >= BINS) b = BINS - 1; counts[b]++; }
        density = counts.map((c) => c / SAMPLES / binW);
        const mu = n / 2, sg = Math.sqrt(n / 12); curve = [];
        for (let i = 0; i <= 96; i++) { const x = (i / 96) * n; curve.push(Math.exp(-((x - mu) ** 2) / (2 * sg * sg)) / (sg * Math.sqrt(2 * Math.PI))); }
        peak = Math.max(Math.max(...density), Math.max(...curve), 1e-6);
      }
      const yOf = (d: number) => BASE + (d / peak) * (TOP - BASE) * 0.92;
      function draw() {
        gl.clearColor(0.957, 0.945, 0.91, 1); gl.clear(gl.COLOR_BUFFER_BIT);
        drawTris(rect(-0.95, BASE - 0.006, 0.95, BASE + 0.006), [0.5, 0.47, 0.43]);
        const bw = 1.8 / BINS, bars: number[] = [];
        for (let i = 0; i < BINS; i++) { const x0 = -0.9 + bw * i; bars.push(...rect(x0 + bw * 0.08, BASE, x0 + bw * 0.92, yOf(density[i]))); }
        drawTris(bars, [0.12, 0.43, 0.55]);
        const poly: number[] = [], w = 0.012;
        for (let i = 0; i < curve.length - 1; i++) { const x0 = -0.9 + (i / (curve.length - 1)) * 1.8, x1 = -0.9 + ((i + 1) / (curve.length - 1)) * 1.8, y0 = yOf(curve[i]), y1 = yOf(curve[i + 1]); poly.push(x0, y0 - w, x1, y1 - w, x1, y1 + w, x0, y0 - w, x1, y1 + w, x0, y0 + w); }
        drawTris(poly, [0.54, 0.18, 0.29]);
      }
      setN = (n: number) => { N = n; sampleN(n); draw(); nEl.textContent = String(n); shapeEl.textContent = n === 1 ? 'flat' : n === 2 ? 'triangular' : n <= 4 ? 'rounding' : 'bell'; };
      resize(); sampleN(1); draw();
    }

    async function engineResult() {
      engineEl.textContent = 'engine…';
      try { const r = await runNoise('use rand; use vec; clt = sum(iid(unif(0,1), 12)) - 6; P(clt > 1)'); engineEl.innerHTML = `engine: P(standardized sum &gt; 1) = <span class="ok">${r.value ?? r.output.trim()}</span> (Normal: 0.159)`; } catch { engineEl.textContent = ''; }
    }

    const io = new IntersectionObserver((es) => { for (const e of es) if (e.isIntersecting && e.intersectionRatio > 0.5) setStep(Number((e.target as HTMLElement).dataset.step)); }, { threshold: [0.5], rootMargin: '-18% 0px -18% 0px' });
    for (const el of root.querySelectorAll('.scrolly-step')) io.observe(el);
    setStep(0);
  }
</script>
