---
// The interactive playground: a Monaco editor and a full-height Preview panel in a resizable split.
// The Preview typesets the one `Document` a run returns (PLAN-LITERATE §D5) as a journal-style paper:
// a header (title + abstract + keywords, all from the file's frontmatter), emitted notes as body
// prose, plots as numbered figures, and code as clean listings whose comments hide into margin notes.
// Inline `input::…` parameters render as sliders in the paper flow that re-run on change; the URL
// fragment stays live and shareable (#x=<id> / #c=<encoded>, plus #i=name:value for tuned inputs).
---

<section id="playground" class="playground">
  <div class="pg-split" id="pg-split" data-view="split">
    <div class="pg-editor-wrap glass">
      <div class="pg-toolbar">
        <div class="pg-viewtabs pg-viewtabs-edit" role="group" aria-label="Choose editor and render layout">
          <button class="pg-viewtab" data-view="code" type="button" aria-pressed="false" title="Editor only">
            <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true"><path d="M9 8l-4 4 4 4"></path><path d="M15 8l4 4-4 4"></path></svg>
            <span>Code</span>
          </button>
          <button class="pg-viewtab pg-viewtab-split" data-view="split" type="button" aria-pressed="false" title="Editor and render side by side">
            <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true"><rect x="4" y="5" width="7" height="14" rx="1"></rect><rect x="13" y="5" width="7" height="14" rx="1"></rect></svg>
            <span>Split</span>
          </button>
          <button class="pg-viewtab" data-view="render" type="button" aria-pressed="false" title="Render only">
            <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true"><rect x="4" y="5" width="16" height="14" rx="1"></rect><path d="M4 9h16"></path></svg>
            <span>Render</span>
          </button>
        </div>
        <div class="pg-toolbar-right">
          <label class="pg-select-wrap">
            <select id="pg-select" class="pg-select" aria-label="Choose an example"></select>
          </label>
          <button id="pg-run" class="btn btn-run" type="button" title="Run (⌘↵)">
            <span class="btn-icon">▶</span> Run
          </button>
        </div>
      </div>
      <div id="editor" class="pg-editor"></div>
    </div>

    <div
      class="pg-resizer"
      id="pg-resizer"
      role="separator"
      aria-orientation="vertical"
      aria-label="Resize editor and output"
      tabindex="0"
    ></div>

    <div class="pg-output-wrap glass">
      <div class="pg-output-head">
        <div class="pg-head-left">
          <div class="pg-viewtabs pg-viewtabs-out" role="group" aria-label="Choose editor and render layout">
            <button class="pg-viewtab" data-view="code" type="button" aria-pressed="false" title="Editor only">
              <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true"><path d="M9 8l-4 4 4 4"></path><path d="M15 8l4 4-4 4"></path></svg>
              <span>Code</span>
            </button>
            <button class="pg-viewtab pg-viewtab-split" data-view="split" type="button" aria-pressed="false" title="Editor and render side by side">
              <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true"><rect x="4" y="5" width="7" height="14" rx="1"></rect><rect x="13" y="5" width="7" height="14" rx="1"></rect></svg>
              <span>Split</span>
            </button>
            <button class="pg-viewtab" data-view="render" type="button" aria-pressed="false" title="Render only">
              <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true"><rect x="4" y="5" width="16" height="14" rx="1"></rect><path d="M4 9h16"></path></svg>
              <span>Render</span>
            </button>
          </div>
        </div>
        <div class="pg-head-right">
          <div id="pg-metrics" class="pg-metrics" hidden></div>
          <div class="pg-share" id="pg-share">
            <button
              id="pg-share-btn"
              class="pg-share-btn"
              type="button"
              aria-haspopup="menu"
              aria-expanded="false"
              aria-label="Share this program"
            >
              <svg class="pg-share-ico" viewBox="0 0 24 24" width="12" height="12" aria-hidden="true">
                <circle cx="18" cy="5" r="2.6"></circle>
                <circle cx="6" cy="12" r="2.6"></circle>
                <circle cx="18" cy="19" r="2.6"></circle>
                <line x1="8.2" y1="10.8" x2="15.8" y2="6.2"></line>
                <line x1="8.2" y1="13.2" x2="15.8" y2="17.8"></line>
              </svg>
              <span>Share</span>
            </button>
            <div class="pg-share-menu" id="pg-share-menu" role="menu" hidden>
              <div class="pg-share-menu-label">Copy link</div>
              <button class="pg-share-url" id="pg-share-url" type="button" role="menuitem" title="Copy link to clipboard">
                <span class="pg-share-url-text" id="pg-share-url-text"></span>
                <span class="pg-share-copy" id="pg-share-copy">Copy</span>
              </button>
              <button class="pg-share-pdf" id="pg-share-pdf" type="button" role="menuitem">
                <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true">
                  <path d="M12 3v11m0 0l-4-4m4 4l4-4"></path>
                  <path d="M5 20h14"></path>
                </svg>
                Download as PDF
              </button>
            </div>
          </div>
        </div>
      </div>
      <div id="pg-output" class="pg-output is-preview"><span class="muted">Press Run to evaluate.</span></div>
    </div>
  </div>
</section>

<style>
  .playground { max-width: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1rem; }

  /* Segmented control to switch the layout between Code-only, Split, and Render-only. It lives in the
     header rows (never its own bar, to save vertical space): a copy in the editor toolbar carries it
     in Code view, and a copy in the Render header carries it in Split/Render — exactly one shows per
     view, so there's always one control, pinned to the far right. Both drive the same persisted state.
     The Split segment is hidden on narrow screens where a two-pane split can't breathe. */
  .pg-viewtabs {
    display: inline-flex; align-items: stretch; gap: 2px;
    padding: 1px; border: 1px solid var(--rule); border-radius: 8px; background: var(--paper-2);
  }
  /* The editor-toolbar copy leads the left (editor) panel and carries the toggle whenever the editor
     is shown — Code and Split. Only in Render-only, where the editor panel is gone, does the
     Render-header copy take over. So exactly one shows per view, always at the far left. */
  .pg-viewtabs-edit { display: none; }
  .pg-split[data-view='code'] .pg-viewtabs-edit,
  .pg-split[data-view='split'] .pg-viewtabs-edit { display: inline-flex; }
  .pg-viewtabs-out { display: none; }
  .pg-split[data-view='render'] .pg-viewtabs-out { display: inline-flex; }
  /* Toggle on the far left of the editor toolbar; the selector + Run ride together on the far right,
     with the selector free to shrink so the row never wraps in the narrow split pane. */
  .pg-toolbar-right { display: inline-flex; align-items: center; gap: 0.5rem; margin-left: auto; min-width: 0; }
  .pg-toolbar-right .pg-select-wrap { min-width: 0; }
  .pg-toolbar-right .pg-select { min-width: 0; }
  /* Left cluster of the Render header: the view toggle (Render-only) + the "Render" label. */
  .pg-head-left { display: inline-flex; align-items: center; gap: 0.6rem; min-width: 0; }
  .pg-viewtab {
    font: inherit; font-size: 0.72rem; font-variant: small-caps; letter-spacing: 0.05em;
    line-height: 1; color: var(--ink-dim); background: transparent;
    border: 1px solid transparent; border-radius: 6px;
    padding: 0.12rem 0.6rem; cursor: pointer;
    display: inline-flex; align-items: center; gap: 0.36rem;
    transition: background 0.15s ease, color 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .pg-viewtab svg { stroke: currentColor; stroke-width: 1.9; fill: none; stroke-linecap: round; stroke-linejoin: round; }
  .pg-viewtab:hover { color: var(--ink); }
  .pg-viewtab[aria-pressed='true'] {
    color: var(--ink); background: var(--paper); border-color: var(--rule);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
  }
  .pg-viewtab:focus-visible { outline: 2px solid var(--link); outline-offset: 1px; }

  /* A resizable two-pane split. `--pg-left` is the editor's width fraction, dragged by the handle. */
  .pg-split {
    display: grid;
    grid-template-columns: minmax(220px, var(--pg-left, 40%)) 10px minmax(280px, 1fr);
    align-items: stretch;
    min-height: clamp(460px, calc(100vh - 13rem), 940px);
  }
  /* Single-pane views: collapse to one column and hide the resizer + the pane being focused away. */
  .pg-split[data-view='code'],
  .pg-split[data-view='render'] { grid-template-columns: 1fr; }
  .pg-split[data-view='code'] .pg-resizer,
  .pg-split[data-view='code'] .pg-output-wrap,
  .pg-split[data-view='render'] .pg-resizer,
  .pg-split[data-view='render'] .pg-editor-wrap { display: none; }

  @media (max-width: 880px) {
    .pg-split { grid-template-columns: 1fr; min-height: 0; gap: 1rem; }
    .pg-resizer { display: none; }
    .pg-viewtab-split { display: none; }
  }

  .pg-resizer {
    cursor: col-resize;
    align-self: stretch;
    position: relative;
    border-radius: 4px;
  }
  .pg-resizer::before {
    content: '';
    position: absolute; inset: 0 3px;
    border-radius: 4px;
    background: var(--rule);
    transition: background 0.15s ease;
  }
  .pg-resizer:hover::before, .pg-resizer:focus-visible::before { background: var(--accent); }
  .pg-resizer:focus-visible { outline: none; }

  .pg-editor-wrap { display: flex; flex-direction: column; overflow: hidden; }
  /* Toolbar and the Preview header share one height (--pg-head) so the two panels line up at the top. */
  .pg-toolbar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: var(--pg-head, 2.3rem);
    box-sizing: border-box;
    /* Same horizontal padding as the Render header (.pg-output-head) so the view toggle sits at the
       exact same x in both — it must not shift when the visible copy swaps between the two. */
    padding: 0.3rem 0.85rem;
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
    flex-wrap: nowrap;
  }
  .pg-editor { flex: 1; min-height: 0; height: auto; width: 100%; }
  @media (max-width: 880px) { .pg-editor { flex: none; height: 320px; } }

  .pg-select-wrap { position: relative; display: inline-flex; }
  .pg-select {
    appearance: none;
    font: inherit;
    font-size: 0.82rem;
    color: var(--ink);
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-radius: 4px;
    /* Compact vertical padding so the toolbar keeps to --pg-head and lines up with the Render header. */
    padding: 0.12rem 1.7rem 0.12rem 0.6rem;
    cursor: pointer;
    max-width: 230px;
  }
  .pg-select:hover { border-color: var(--accent); }
  .pg-select:focus-visible { outline: 2px solid var(--link); }
  .pg-select-wrap::after {
    content: '▾';
    position: absolute; right: 0.65rem; top: 50%; transform: translateY(-50%);
    pointer-events: none; color: var(--ink-dim); font-size: 0.75rem;
  }

  .btn {
    font: inherit;
    font-size: 0.82rem;
    border-radius: 4px;
    padding: 0.12rem 0.65rem;
    cursor: pointer;
    border: 1px solid var(--rule);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: transform 0.08s ease, background 0.15s ease, color 0.15s ease;
  }
  .btn:active { transform: translateY(1px); }
  .btn-run {
    background: var(--ink);
    color: var(--paper);
    font-weight: 600;
    border-color: var(--ink);
  }
  .btn-run:hover { background: #000; }
  .btn-run[disabled] { opacity: 0.55; cursor: progress; }
  .btn-icon { font-size: 0.7em; }
  .kbd {
    font-size: 0.68rem;
    opacity: 0.65;
    border: 1px solid currentColor;
    border-radius: 4px;
    padding: 0 0.28rem;
  }

  /* Full-height, tabbed output. */
  .pg-output-wrap { display: flex; flex-direction: column; overflow: hidden; min-height: 260px; }

  .pg-output-head {
    display: flex; align-items: center; justify-content: space-between; gap: 0.6rem 1rem;
    flex-wrap: wrap;
    min-height: var(--pg-head, 2.3rem);
    box-sizing: border-box;
    padding: 0.3rem 0.85rem;
    border-bottom: 1px solid var(--rule);
    font-size: 0.76rem; font-variant: small-caps; letter-spacing: 0.06em; color: var(--ink-dim);
    background: var(--paper);
  }

  .pg-output {
    margin: 0; padding: 0.85rem; flex: 1; overflow: auto;
    font-family: var(--mono); font-size: 0.86rem; line-height: 1.5;
    color: var(--ink); word-break: break-word;
    background: var(--paper-2);
  }
  /* The Preview background is on the markup element, so it can stay scoped; its dynamically-built
     children are styled by the `<style is:global>` block below (Astro scoping doesn't reach
     JS-created nodes). */
  .pg-output.is-preview { background: var(--paper); padding: 1.6rem 1.4rem 2.4rem; }

  /* Engine readout — inline in the Preview header, right-aligned. */
  .pg-metrics {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0;
    font-variant: normal;
    color: var(--ink-dim);
    text-align: right;
  }
  .pg-metric { white-space: nowrap; }
  .pg-metrics[hidden] { display: none; }
  .pg-metric .m-key { font-variant: small-caps; letter-spacing: 0.04em; color: var(--ink-faint); }
  .pg-metric .m-val { color: var(--ink); font-weight: 700; }
  .pg-metric.m-rate .m-val { color: var(--accent); }
  .m-sep { color: var(--ink-faint); opacity: 0.6; }

  /* The right cluster of the Render header: the engine readout + the Share pill. */
  .pg-head-right { display: inline-flex; align-items: center; gap: 0.6rem; min-width: 0; }

  /* Share pill + its dropdown (copy link / download PDF). */
  .pg-share { position: relative; flex: none; }
  .pg-share-btn {
    display: inline-flex; align-items: center; gap: 0.34rem;
    font-family: var(--sans, inherit); font-size: 0.7rem; font-variant: small-caps; letter-spacing: 0.05em;
    color: var(--ink-dim); background: var(--paper);
    border: 1px solid var(--rule); border-radius: 999px;
    padding: 0.18rem 0.6rem; cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .pg-share-btn:hover, .pg-share-btn[aria-expanded='true'] {
    color: var(--ink); border-color: var(--accent); background: var(--paper-2);
  }
  .pg-share-ico { stroke: currentColor; stroke-width: 1.8; fill: none; }
  .pg-share-ico circle { fill: currentColor; stroke: none; }

  .pg-share-menu {
    position: absolute; top: calc(100% + 0.4rem); right: 0; z-index: 30;
    width: min(340px, 78vw);
    display: flex; flex-direction: column; gap: 0.25rem;
    padding: 0.5rem; box-sizing: border-box;
    background: var(--paper); border: 1px solid var(--rule); border-radius: 8px;
    box-shadow: 0 10px 30px -8px rgba(0, 0, 0, 0.25);
  }
  .pg-share-menu[hidden] { display: none; }
  .pg-share-menu-label {
    font-size: 0.64rem; font-variant: small-caps; letter-spacing: 0.08em;
    color: var(--ink-faint); padding: 0.1rem 0.25rem 0.15rem;
  }
  .pg-share-url {
    display: flex; align-items: center; gap: 0.5rem; width: 100%;
    padding: 0.4rem 0.5rem; text-align: left; cursor: pointer;
    background: var(--paper-2); border: 1px solid var(--rule); border-radius: 6px;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .pg-share-url:hover { border-color: var(--accent); }
  .pg-share-url-text {
    flex: 1; min-width: 0; overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
    font-family: var(--mono); font-size: 0.72rem; color: var(--ink-dim); direction: rtl; text-align: left;
  }
  .pg-share-copy {
    flex: none; font-size: 0.66rem; font-variant: small-caps; letter-spacing: 0.05em; font-weight: 700;
    color: var(--accent);
  }
  .pg-share.copied .pg-share-copy { color: #2e7d32; }
  .pg-share-pdf {
    display: flex; align-items: center; gap: 0.45rem; width: 100%;
    padding: 0.42rem 0.5rem; text-align: left; cursor: pointer;
    font-family: var(--sans, inherit); font-size: 0.78rem; color: var(--ink);
    background: transparent; border: 1px solid transparent; border-radius: 6px;
    transition: background 0.15s ease;
  }
  .pg-share-pdf:hover { background: var(--paper-2); }
  .pg-share-pdf svg { stroke: currentColor; stroke-width: 1.9; fill: none; stroke-linecap: round; stroke-linejoin: round; }

  /* --- Result cards (one per `plot::*` / introspection item) --- */
  .pg-card { border: 1px solid var(--rule); border-radius: 6px; background: var(--paper); padding: 0.6rem 0.7rem; }
  .pg-card-text { font-family: var(--mono); font-size: 0.72rem; color: var(--ink-dim); line-height: 1.5; overflow-wrap: anywhere; }
  .pg-card-title { color: var(--ink); font-weight: 700; }
  .pg-chart { margin-top: 0.4rem; overflow-x: auto; }
  .pg-chart:empty { display: none; }
  .pg-chart .vega-embed { width: 100%; }
  .pg-chart summary { display: none; }
  .pg-inspect-err { font-family: var(--mono); font-size: 0.76rem; color: #a4262c; }
</style>

<!--
  Preview content is built in JS, so Astro's scoped styles don't reach it. These rules are global,
  contained to the playground by the `#pg-output` id prefix. They typeset the Document as a paper.
-->
<style is:global>
  #pg-output.is-preview { container-type: inline-size; }
  #pg-output.is-preview .muted { color: var(--ink-faint); }
  #pg-output .pg-paper {
    max-width: 660px; margin: 0 auto;
    font-family: var(--serif); font-size: 1.04rem; line-height: 1.62; color: var(--ink);
  }
  /* On a wide panel, reserve a right gutter for the margin notes (text left, notes right). The gutter
     is a right padding so the text column (600) + gutter (250) form one 850-wide block that stays
     centred — otherwise a full-width Render pane would strand the text against the right edge. */
  @container (min-width: 781px) {
    #pg-output .pg-paper {
      box-sizing: border-box;
      max-width: 850px;
      margin-left: auto;
      margin-right: auto;
      padding-right: 250px;
    }
  }

  /* Paper header: the frontmatter title + abstract + keywords, typeset like a journal article.
     Everything is left-aligned to one shared margin so title, abstract, and keywords line up. */
  #pg-output .pg-paper-head { text-align: left; margin: 0 0 1.9rem; padding-bottom: 1.4rem; border-bottom: 1px solid var(--rule); }
  #pg-output .pg-paper-title {
    font-family: var(--serif); font-size: 1.9rem; font-weight: 700; line-height: 1.15;
    letter-spacing: -0.01em; color: var(--ink); margin: 0.2rem 0 1.1rem;
  }
  /* Abstract, matching the front page: a left rule with an inline run-in "Abstract." bold label. */
  #pg-output .pg-abstract { border-left: 2px solid var(--rule); padding: 0.1rem 0 0.1rem 1.2rem; margin: 0; }
  #pg-output .pg-abstract-body {
    font-family: var(--serif); font-size: 1.02rem; line-height: 1.6;
    hyphens: auto; color: var(--ink); margin: 0;
  }
  #pg-output .pg-abstract-label { font-weight: 700; }
  #pg-output .pg-keywords { font-family: var(--serif); font-size: 0.82rem; color: var(--ink-faint); margin: 0.9rem 0 0; }
  #pg-output .pg-keywords em { font-style: italic; color: var(--ink-dim); }

  /* Emitted notes = the paper's body prose. */
  #pg-output .pg-para { margin: 0.85rem 0; }
  #pg-output .pg-para-plain { white-space: pre-wrap; }
  /* LaTeX notes: KaTeX display equations, one per line, left-aligned like a paper's numbered maths. */
  #pg-output .pg-latex { margin: 1rem 0; }
  #pg-output .pg-latex-eq { overflow-x: auto; overflow-y: hidden; padding: 0.15rem 0; }
  #pg-output .pg-latex-eq > .katex-display { margin: 0.35rem 0; text-align: left; }
  #pg-output .pg-latex-eq > .katex-display > .katex { text-align: left; }
  #pg-output .pg-para .pg-md-h { font-family: var(--serif); font-weight: 700; color: var(--ink); margin: 1.2rem 0 0.4rem; font-size: 1.18rem; }
  #pg-output .pg-para .pg-md-p { margin: 0.5rem 0; }
  #pg-output .pg-para .pg-md-ul { margin: 0.5rem 0 0.5rem 1.2rem; }
  #pg-output .pg-para code { font-family: var(--mono); font-size: 0.86em; background: var(--paper-2); padding: 0 0.28em; border-radius: 3px; }

  /* Code listings: comments stripped from the page, revealed on hover like margin notes. */
  #pg-output .pg-codecard { position: relative; margin: 1.1rem 0; }
  #pg-output.is-preview .code-body {
    margin: 0; padding: 0.65rem 0.85rem;
    font-family: var(--mono); font-size: 0.82rem; line-height: 1.6;
    border: 1px solid var(--rule); border-radius: 6px; background: var(--paper-2);
    overflow-x: auto; white-space: pre;
  }
  #pg-output .pg-codecard.has-note .code-body { box-shadow: inset 3px 0 0 var(--accent); cursor: help; }
  /* Notes & figures carry the same affordance: an accent spine on the block's *own* box (never a
     padded wrapper, so annotated and plain blocks keep the same left edge) + a hover tag. */
  #pg-output .pg-para.has-note {
    position: relative; cursor: help;
    padding-left: 0.9rem; box-shadow: inset 3px 0 0 var(--accent); border-radius: 4px;
  }
  #pg-output .pg-figure.has-note { position: relative; cursor: help; }
  #pg-output .pg-figure.has-note .figure-frame { box-shadow: inset 3px 0 0 var(--accent); }

  /* Inline input control (`input::…`): a small framed widget sitting in the paper flow, right after
     the code that declares it. A slider + number box (or a checkbox), so a reader tunes the
     parameter and the page re-runs in place. */
  #pg-output .pg-input {
    position: relative;
    display: flex; align-items: center; gap: 0.55rem; flex-wrap: wrap;
    margin: 1.1rem 0; padding: 0.5rem 0.75rem;
    border: 1px solid var(--rule); border-radius: 6px; background: var(--paper-2);
    font-family: var(--sans); font-size: 0.82rem; color: var(--ink-dim);
  }
  #pg-output .pg-input.has-note { cursor: help; box-shadow: inset 3px 0 0 var(--accent); }
  #pg-output .pg-input-name { font-variant: small-caps; letter-spacing: 0.03em; color: var(--ink); }
  #pg-output .pg-input input[type='range'] { flex: 1; min-width: 120px; accent-color: var(--accent); cursor: pointer; }
  #pg-output .pg-input input[type='checkbox'] { accent-color: var(--accent); cursor: pointer; }
  #pg-output .pg-input-num {
    width: 4.6rem; font-family: var(--mono); font-size: 0.8rem; color: var(--ink);
    background: var(--paper); border: 1px solid var(--rule); border-radius: 4px; padding: 0.12rem 0.35rem;
  }
  #pg-output .pg-note-tag {
    position: absolute; top: 0.4rem; right: 0.55rem;
    font-family: var(--sans); font-size: 0.68rem; font-style: normal; color: var(--ink-faint);
    opacity: 0.5; transition: opacity 0.15s ease; pointer-events: none;
  }
  #pg-output .has-note:hover > .pg-note-tag { opacity: 0.9; color: var(--accent); }
  /* Margin note: a floating card in the right margin, revealed on hover. Absolutely positioned so it
     never shifts the page (LaTeX \marginpar). On a narrow panel it drops just below the listing. */
  #pg-output .pg-annot {
    position: absolute; top: 0; right: 0;
    transform: translateX(calc(100% + 14px));
    width: 210px; max-width: 46cqw;
    opacity: 0; pointer-events: none;
    transition: opacity 0.18s ease, transform 0.18s ease;
    font-family: var(--serif); font-style: italic; font-size: 0.9rem; line-height: 1.5;
    color: var(--ink-dim);
    background: var(--paper);
    border: 1px solid var(--rule); border-left: 3px solid var(--accent); border-radius: 6px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
    padding: 0.45rem 0.65rem;
    z-index: 5;
  }
  #pg-output .has-note:hover > .pg-annot { opacity: 1; transform: translateX(calc(100% + 10px)); }
  #pg-output .pg-annot-line { margin: 0.16rem 0; }
  #pg-output .pg-annot-line:first-child { margin-top: 0; }
  #pg-output .pg-annot-line:last-child { margin-bottom: 0; }
  @container (max-width: 780px) {
    #pg-output .pg-annot {
      transform: none; right: 0.3rem; top: calc(100% + 4px);
      width: min(320px, 88cqw); max-width: none;
    }
    #pg-output .has-note:hover > .pg-annot { transform: none; }
  }

  /* Plots = numbered figures (reuse the global `.figure`/`.figure-frame`/`.figure-caption`). */
  #pg-output .pg-figure { margin: 1.5rem 0; }
  #pg-output .pg-figure .figure-frame { padding: 0.6rem 0.5rem 0.3rem; display: flex; justify-content: center; background: var(--paper); }
  #pg-output .pg-figure .figure-frame .pg-chart { width: 100%; margin-top: 0; }
  #pg-output .pg-figure .figure-caption { text-align: left; font-style: italic; margin-top: 0.5rem; padding: 0 0.4rem; }
  #pg-output .pg-figure .pg-fig-title { font-family: var(--mono); font-style: normal; font-size: 0.9em; color: var(--ink); }

  /* Concluding result / error, centered under the body. */
  #pg-output .pg-final { text-align: center; margin: 1.4rem 0 0; font-size: 1.05rem; }
  #pg-output .pg-final .pg-final-mark { color: var(--ink-faint); }
  #pg-output .pg-final .val { color: #9a5b00; font-weight: 700; font-family: var(--mono); }
  #pg-output .pg-final .err { color: #a4262c; font-family: var(--mono); font-size: 0.9rem; }

  /* Chart mounts + no-chart text card (also JS-built). */
  #pg-output .pg-chart { overflow-x: auto; }
  #pg-output .pg-chart .vega-embed { width: 100%; }
  #pg-output .pg-chart summary { display: none; }
  #pg-output .pg-card-text { font-family: var(--mono); font-size: 0.72rem; color: var(--ink-dim); line-height: 1.5; overflow-wrap: anywhere; }
  #pg-output .pg-inspect-err { font-family: var(--mono); font-size: 0.76rem; color: #a4262c; }

  /* "Download as PDF" prints just the typeset paper — everything else is hidden, and the output
     panel is lifted to the top-left of the page so the browser's "Save as PDF" captures the article
     alone (the hover-only margin notes stay hidden, which is what we want on paper). */
  @media print {
    @page { margin: 1.6cm; }
    body * { visibility: hidden !important; }
    #pg-output, #pg-output * { visibility: visible !important; }
    #pg-output {
      position: absolute !important; left: 0 !important; top: 0 !important;
      width: 100% !important; height: auto !important; overflow: visible !important;
      padding: 0 !important; background: #fff !important;
    }
    #pg-output .pg-paper { max-width: 100% !important; margin: 0 !important; }
    #pg-output .pg-annot { display: none !important; }
  }
</style>

<script>
  import * as monaco from 'monaco-editor/esm/vs/editor/editor.api';
  import EditorWorker from 'monaco-editor/esm/vs/editor/editor.worker?worker';
  import { registerNoise, LANGUAGE_ID, THEME_ID } from '../lib/noise-lang';
  import {
    runNoiseWithIntrospection,
    noiseMeta,
    type NoiseIntrospectResult,
    type Plot,
    type Block,
    type Span,
    type InputBlock,
    type InputValue,
  } from '../lib/noise';
  import { examples, defaultExampleId, examplesByCategory } from '../data/examples';
  import { parseHash, encodeCode, encodeInputs, type InputHashValue } from '../lib/share';
  import { LISTING_HL } from '../lib/highlight';
  import katex from 'katex';
  import 'katex/dist/katex.min.css';

  (self as any).MonacoEnvironment = { getWorker: () => new EditorWorker() };

  const $ = (id: string) => document.getElementById(id)!;
  const outEl = $('pg-output');
  const metricsEl = $('pg-metrics');
  const select = $('pg-select') as HTMLSelectElement;

  registerNoise(monaco);

  const byId = new Map(examples.map((e) => [e.id, e]));

  for (const group of examplesByCategory()) {
    const og = document.createElement('optgroup');
    og.label = group.category;
    for (const ex of group.items) {
      const opt = document.createElement('option');
      opt.value = ex.id;
      opt.textContent = ex.title;
      og.appendChild(opt);
    }
    select.appendChild(og);
  }
  // A hidden option shown only when the code no longer matches any gallery example — the selector
  // then reads "Custom" instead of going blank. Not listed in the dropdown (there's nothing to pick).
  const CUSTOM_VALUE = '__custom__';
  const customOpt = document.createElement('option');
  customOpt.value = CUSTOM_VALUE;
  customOpt.textContent = 'Custom';
  customOpt.hidden = true;
  select.insertBefore(customOpt, select.firstChild);

  let currentId: string | null = defaultExampleId;
  let suppressHash = false;
  // `lastResult` is the last `Document`, so re-rendering never needs a fresh run of everything.
  let lastResult: NoiseIntrospectResult | null = null;
  // Host **input overrides** keyed by input name (defaults + user/shared overrides). Inputs
  // themselves are discovered from the run (`result.inputs`), so there is no pre-run declaration list.
  let inputValues: Record<string, InputValue> = {};
  // The title/abstract/tags to typeset in the paper header (from the selected file's frontmatter),
  // so the header shows before the first run too. After a run, `renderPreview` uses `res.meta`.
  let currentHeaderMeta: { title?: string; abstract?: string; tags?: string[] } | null = null;

  // The layout view (Code / Split / Render). Declared up here (before `shareHash`/`loadFromHash`
  // run) so the fragment can carry it and reloads restore it. Source of truth on load: the `v=`
  // fragment param, then the persisted preference, then Split. The controls are wired further down.
  const VIEW_KEY = 'noise-pg-view';
  type ViewMode = 'code' | 'split' | 'render';
  const isViewMode = (v: unknown): v is ViewMode => v === 'code' || v === 'split' || v === 'render';
  const readView = (): ViewMode => {
    const fromHash = parseHash(location.hash).view;
    if (isViewMode(fromHash)) return fromHash;
    try {
      const v = localStorage.getItem(VIEW_KEY);
      if (isViewMode(v)) return v;
    } catch {}
    return 'split';
  };
  let viewPref: ViewMode = readView();

  const editor = monaco.editor.create($('editor'), {
    value: byId.get(defaultExampleId)?.code ?? examples[0]?.code ?? '',
    language: LANGUAGE_ID,
    theme: THEME_ID,
    fontSize: 14,
    fontFamily: 'ui-monospace, SFMono-Regular, "JetBrains Mono", Menlo, monospace',
    fontLigatures: true,
    minimap: { enabled: false },
    scrollBeyondLastLine: false,
    wordWrap: 'on',
    padding: { top: 14, bottom: 14 },
    lineNumbers: 'on',
    renderLineHighlight: 'line',
    smoothScrolling: true,
    automaticLayout: true,
    scrollbar: { verticalScrollbarSize: 8, horizontalScrollbarSize: 8 },
  });

  /** Paint the pre-run page: the paper header (from the frontmatter `meta`) + a "press run" body.
   * The header is the same one a completed run shows — `meta()` parses the frontmatter without
   * running, so the title/abstract appear (and update as you type) before any sampling happens. */
  function showPreRunPage() {
    outEl.innerHTML = '';
    const page = document.createElement('div');
    page.className = 'pg-paper';
    const header = currentHeaderMeta ? renderPaperHeader(currentHeaderMeta) : null;
    if (header) page.appendChild(header);
    const ph = document.createElement('div');
    ph.className = 'pg-final muted';
    ph.textContent = 'Press Run to evaluate.';
    page.appendChild(ph);
    outEl.appendChild(page);
  }

  function clearOutput() {
    lastResult = null;
    showPreRunPage();
    metricsEl.hidden = true;
    metricsEl.innerHTML = '';
  }

  function setHash(value: string) {
    suppressHash = true;
    history.replaceState(null, '', value);
    setTimeout(() => (suppressHash = false), 0);
  }

  /** Input overrides that differ from their declared default — the only ones a share link carries.
   *  Inputs are known only after a run (`result.inputs`), so this reads the last run's manifest. */
  function nonDefaultInputs(): Record<string, InputHashValue> {
    const out: Record<string, InputHashValue> = {};
    for (const s of lastResult?.result.inputs ?? []) {
      const v = inputValues[s.name];
      if (v !== undefined && v !== s.default) out[s.name] = v as InputHashValue;
    }
    return out;
  }

  // The shareable fragment: #x=id (unmodified example) or #c=snapshot, plus #i=name:value for any
  // tuned inputs and #v=view for a non-default layout — so a tuned example in a chosen view is
  // shareable exactly as seen. The default Split view is left off to keep the common link clean.
  function shareHash(): string {
    const code = editor.getValue();
    const ex = currentId ? byId.get(currentId) : undefined;
    let hash = ex && ex.code.trim() === code.trim() ? `#x=${currentId}` : `#c=${encodeCode(code)}`;
    const nd = nonDefaultInputs();
    if (Object.keys(nd).length) hash += `&i=${encodeInputs(nd)}`;
    if (viewPref !== 'split') hash += `&v=${viewPref}`;
    return hash;
  }

  /** Read the program's frontmatter and refresh the pre-run paper header (title/abstract/tags), so
   *  editing them updates the header live before the first run. Inputs are no longer parsed here —
   *  they come from the run itself (`result.inputs`). */
  async function refreshHeader() {
    const code = editor.getValue();
    let headerMeta = currentHeaderMeta;
    try {
      const m = await noiseMeta(code);
      if (m.ok) headerMeta = { title: m.title, abstract: m.abstract, tags: m.tags };
    } catch {
      /* keep the previous header on a parse hiccup */
    }
    // Guard against a race: only apply if the code hasn't changed since we asked.
    if (code !== editor.getValue()) return;
    currentHeaderMeta = headerMeta;
    // Reflect a freshly-parsed header while the user hasn't run yet (a run repaints it from res.meta).
    if (!lastResult) showPreRunPage();
  }

  /** Render one inline input control (PLAN-INPUTS §4): a labelled slider + number box, or a checkbox
   *  for a bool. Dragging it overrides that input by name and re-runs (debounced), in place. */
  function renderInputControl(b: InputBlock): HTMLElement {
    const row = document.createElement('label');
    row.className = 'pg-input';
    const name = document.createElement('span');
    name.className = 'pg-input-name';
    name.textContent = b.label ?? b.name;
    row.appendChild(name);
    const val = inputValues[b.name] ?? b.value;
    if (b.type === 'bool') {
      const cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.checked = Boolean(val);
      cb.addEventListener('change', () => setInput(b.name, cb.checked));
      row.appendChild(cb);
    } else {
      const step = b.step !== undefined ? String(b.step) : b.type === 'int' ? '1' : 'any';
      const range = document.createElement('input');
      range.type = 'range';
      if (b.min !== undefined) range.min = String(b.min);
      if (b.max !== undefined) range.max = String(b.max);
      range.step = step;
      range.value = String(val);
      const num = document.createElement('input');
      num.type = 'number';
      num.className = 'pg-input-num';
      if (b.min !== undefined) num.min = String(b.min);
      if (b.max !== undefined) num.max = String(b.max);
      num.step = step;
      num.value = String(val);
      const sync = (v: number) => {
        range.value = String(v);
        num.value = String(v);
        setInput(b.name, v);
      };
      range.addEventListener('input', () => sync(Number(range.value)));
      num.addEventListener('change', () => sync(Number(num.value)));
      row.appendChild(range);
      row.appendChild(num);
    }
    return row;
  }

  let inputTimer = 0;
  function setInput(name: string, value: InputValue) {
    inputValues[name] = value;
    setHash(shareHash());
    // Debounced re-run so dragging a slider stays responsive.
    window.clearTimeout(inputTimer);
    inputTimer = window.setTimeout(execute, 180);
  }

  function selectExample(id: string, opts: { loadCode?: boolean; updateHash?: boolean; inputs?: Record<string, InputHashValue>; autoRun?: boolean } = {}) {
    const { loadCode = true, updateHash = true, inputs, autoRun = false } = opts;
    const ex = byId.get(id);
    if (!ex) return;
    currentId = id;
    currentHeaderMeta = { title: ex.title, abstract: ex.abstract, tags: ex.tags };
    select.value = id;
    inputValues = { ...(inputs ?? {}) };
    if (loadCode) editor.setValue(ex.code);
    if (updateHash) setHash(viewPref !== 'split' ? `#x=${id}&v=${viewPref}` : `#x=${id}`);
    clearOutput();
    // Refresh the header, then auto-run — inputs (and their controls) come from the run itself.
    void refreshHeader().then(() => { if (autoRun) void execute(); });
  }

  function loadCustom(code: string, inputs?: Record<string, InputHashValue>, opts: { autoRun?: boolean } = {}) {
    currentId = null;
    // A shared/edited program carries its own frontmatter; the header fills in from `res.meta` on run.
    currentHeaderMeta = null;
    select.value = CUSTOM_VALUE;
    inputValues = { ...(inputs ?? {}) };
    editor.setValue(code);
    clearOutput();
    void refreshHeader().then(() => { if (opts.autoRun) void execute(); });
  }

  function loadFromHash({ updateHash = false } = {}) {
    const parsed = parseHash(location.hash);
    // A `v=` in the link opens (or re-opens, on an external hash change) in that layout.
    if (isViewMode(parsed.view)) viewPref = parsed.view;
    if (parsed.exampleId && byId.has(parsed.exampleId)) {
      selectExample(parsed.exampleId, { loadCode: true, updateHash, inputs: parsed.inputs, autoRun: true });
    } else if (parsed.code !== undefined) {
      loadCustom(parsed.code, parsed.inputs, { autoRun: true });
    } else {
      selectExample(defaultExampleId, { loadCode: false, updateHash: false, autoRun: true });
    }
  }

  loadFromHash();

  select.addEventListener('change', () => {
    if (select.value) selectExample(select.value, { autoRun: true });
  });

  // --- running ---

  async function execute() {
    const runBtn = $('pg-run') as HTMLButtonElement;
    runBtn.disabled = true;
    if (!lastResult) outEl.innerHTML = '<span class="muted">running…</span>';
    metricsEl.hidden = true;
    try {
      const res = await runNoiseWithIntrospection(editor.getValue(), [], { inputs: inputValues });
      lastResult = res;
      renderActive();
      renderMetrics(res);
    } catch (e) {
      outEl.innerHTML = `<span class="err">${escapeHtml(String(e))}</span>`;
    } finally {
      runBtn.disabled = false;
    }
  }

  // --- rendering (both tabs are filters over the same Document) ---

  function renderActive() {
    if (!lastResult) {
      outEl.innerHTML = '<span class="muted">Press Run to evaluate.</span>';
      return;
    }
    renderPreview(lastResult);
  }

  /** The Document rendered as a **typeset paper** — emitted notes as serif prose, plots
   * as numbered figures, and code as clean listings whose comments are stripped from the page and
   * revealed on hover (the way a paper hides its source annotations). Blocks are already in reading
   * order; each code listing gathers the comments that annotate it (from the comment layer). */
  function renderPreview(res: NoiseIntrospectResult) {
    outEl.innerHTML = '';
    liveCards.length = 0;
    const page = document.createElement('div');
    page.className = 'pg-paper';
    outEl.appendChild(page);

    // The paper header — title + abstract + keywords from the file's frontmatter (single source of
    // truth; identical to the pre-run header, which reads the same fields from the gallery metadata).
    const header = renderPaperHeader(res.meta);
    if (header) page.appendChild(header);

    // Attribute each comment to the block it annotates via the engine's `code_span` — the exact
    // statement range the comment attaches to — NOT the comment's own position. A trailing comment
    // sits *past* its statement's `;`, so a positional cutoff would spill it onto the block below.
    // A code listing wins whenever it contains the annotated range (that's where the source lives);
    // a standalone `` `…` ``/```` ```md/latex ```` note (a template segment with no code card) claims
    // comments that fall on it. Sorted by position → notes stay in source order within each block.
    const comments = [...res.comments].sort((a, b) => a.self_span.start - b.self_span.start);
    const within = (outer: Span, inner: Span) => inner.start >= outer.start && inner.end <= outer.end;
    const codeSpans = res.blocks.flatMap((b) => (b.kind === 'code' ? [b.span] : []));
    const insideSomeCode = (s: Span) => codeSpans.some((cs) => within(cs, s));
    const annotsFor: string[][] = res.blocks.map(() => []);
    const detached: string[] = [];
    for (const c of comments) {
      const cs = c.code_span;
      if (!cs) {
        detached.push(stripMarker(c.text));
        continue;
      }
      // A code listing containing the range wins; else a standalone note/figure sitting on it.
      let idx = res.blocks.findIndex((b) => b.kind === 'code' && within(b.span, cs));
      if (idx === -1)
        idx = res.blocks.findIndex(
          (b) => b.kind !== 'code' && !insideSomeCode(b.stmt_span) && within(b.stmt_span, cs),
        );
      if (idx === -1) detached.push(stripMarker(c.text));
      else annotsFor[idx].push(stripMarker(c.text));
    }

    let figN = 0;
    let emissions = 0;
    // A lone `plot::…` line is pure redundancy next to its figure (the caption already names the
    // plot and its args), so we fold the listing away and render only the Figure — carrying the
    // block's comments onto the figure so its hover margin note survives.
    let carried: string[] = [];
    res.blocks.forEach((b, i) => {
      if (b.kind === 'code') {
        if (isLonePlotLine(b.source)) {
          carried = annotsFor[i];
          return;
        }
        // Fold a pure `input::` declaration group: the inline control(s) render on their own (with
        // the block's comment carried onto the first), so the redundant listing is dropped.
        if (isInputOnlyBlock(b.source)) {
          carried = annotsFor[i];
          return;
        }
        // Drop `use`-only import blocks — boilerplate that adds nothing to the typeset paper.
        if (isUseOnlyBlock(b.source)) {
          carried = [];
          return;
        }
        carried = [];
        page.appendChild(renderCodeCard(b.source, annotsFor[i]));
      } else if (b.kind === 'note') {
        carried = [];
        page.appendChild(withMarginNote(renderPara(b), annotsFor[i]));
        emissions++;
      } else if (b.kind === 'input') {
        const annots = [...carried, ...annotsFor[i]];
        carried = [];
        page.appendChild(withMarginNote(renderInputControl(b), annots));
      } else {
        figN++;
        const annots = [...carried, ...annotsFor[i]];
        carried = [];
        page.appendChild(withMarginNote(renderFigure(b, figN), annots));
        emissions++;
      }
    });
    // Detached comments (a blank line cut them from any statement) — fold into the last listing.
    if (detached.length) {
      const lastCard = page.querySelector<HTMLElement>('.pg-codecard:last-of-type');
      if (lastCard) {
        let note = lastCard.querySelector('.pg-annot');
        if (!note) {
          note = document.createElement('div');
          note.className = 'pg-annot';
          lastCard.classList.add('has-note');
          lastCard.appendChild(note);
        }
        for (const text of detached) {
          const line = document.createElement('div');
          line.className = 'pg-annot-line';
          line.textContent = text;
          note.appendChild(line);
        }
      }
    }

    // The concluding result / error, set as a small centered line.
    const final = document.createElement('div');
    final.className = 'pg-final';
    if (!res.ok) {
      final.innerHTML = `<span class="err">${escapeHtml(res.error ?? 'error')}</span>`;
      page.appendChild(final);
    } else if (res.value !== null) {
      final.innerHTML = `<span class="pg-final-mark">⇒</span> <span class="val">${escapeHtml(res.value)}</span>`;
      page.appendChild(final);
    } else if (emissions === 0) {
      final.innerHTML = '<span class="muted">(no output)</span>';
      page.appendChild(final);
    }
    if (res.result.truncated) {
      const t = document.createElement('div');
      t.className = 'pg-final muted';
      t.textContent = `… ${res.result.truncated.dropped} more emissions not shown (output capped)`;
      page.appendChild(t);
    }
  }

  /** The paper's header block: a centered title, a justified abstract, and a keywords line — all from
   * frontmatter. Returns null when there is neither a title nor an abstract (a bare program). */
  function renderPaperHeader(meta: { title?: string; abstract?: string; tags?: string[] }): HTMLElement | null {
    const title = meta.title?.trim();
    const abstract = meta.abstract?.trim();
    const tags = (meta.tags ?? []).filter((t) => t && t.trim());
    if (!title && !abstract) return null;
    const head = document.createElement('header');
    head.className = 'pg-paper-head';
    if (title) {
      const h = document.createElement('h1');
      h.className = 'pg-paper-title';
      h.textContent = title;
      head.appendChild(h);
    }
    if (abstract) {
      const box = document.createElement('div');
      box.className = 'pg-abstract';
      box.innerHTML =
        `<p class="pg-abstract-body">` +
        `<span class="pg-abstract-label">Abstract.</span> ${escapeHtml(abstract)}</p>`;
      head.appendChild(box);
    }
    if (tags.length) {
      const kw = document.createElement('p');
      kw.className = 'pg-keywords';
      kw.innerHTML = `<em>Keywords:</em> ${tags.map(escapeHtml).join(', ')}`;
      head.appendChild(kw);
    }
    return head;
  }

  const stripMarker = (raw: string) => raw.replace(/^\s*(#|\/\/)\s?/, '');

  /** A code listing with its comments stripped from the page. If the block carries annotations, the
   * card is marked (a maroon spine + a corner tag) and reveals them on hover — like margin notes. */
  function renderCodeCard(source: string, annots: string[]): HTMLElement {
    const card = document.createElement('div');
    card.className = 'pg-codecard' + (annots.length ? ' has-note' : '');
    const pre = document.createElement('pre');
    pre.className = 'code-body pg-code-strip';
    pre.innerHTML = LISTING_HL(stripComments(source));
    card.appendChild(pre);
    if (annots.length) {
      const tag = document.createElement('span');
      tag.className = 'pg-note-tag';
      tag.textContent = annots.length > 1 ? `✎ ${annots.length} notes` : '✎ note';
      card.appendChild(tag);
      const note = document.createElement('div');
      note.className = 'pg-annot';
      note.innerHTML = annots.map((a) => `<div class="pg-annot-line">${escapeHtml(a)}</div>`).join('');
      card.appendChild(note);
    }
    return card;
  }

  /** A code block that is nothing but a single `plot::…` statement — its figure stands on its own
   * (the caption already names the plot and its args), so the listing is dropped from the page. */
  function isLonePlotLine(source: string): boolean {
    const stripped = stripComments(source).trim();
    return stripped.length > 0 && !stripped.includes('\n') && /^plot\s*::/.test(stripped);
  }

  /** A code block that is nothing but `use …` imports — pure boilerplate, dropped from the typeset
   * page (only when *every* line is a `use`, so a mixed group keeps its imports in context). */
  function isUseOnlyBlock(source: string): boolean {
    const lines = stripComments(source)
      .split('\n')
      .map((l) => l.trim())
      .filter((l) => l.length > 0);
    return lines.length > 0 && lines.every((l) => /^use\b/.test(l));
  }

  /** A code block whose every statement is an `input::` declaration (`name = input::…`). The inline
   * controls stand in for the listing, so the raw source is dropped from the typeset page. Matches
   * one statement per line — the shape the migrated examples use. */
  function isInputOnlyBlock(source: string): boolean {
    const lines = stripComments(source)
      .split('\n')
      .map((l) => l.trim().replace(/;$/, ''))
      .filter((l) => l.length > 0);
    return lines.length > 0 && lines.every((l) => /^[A-Za-z_]\w*\s*=\s*input\s*::/.test(l));
  }

  /** Strip line comments (`#` / `//`, outside strings) from a code listing for the typeset page,
   * dropping any line that was comment-only, and trimming blank edges. */
  function stripComments(source: string): string {
    const out: string[] = [];
    for (const line of source.split('\n')) {
      let inStr = false;
      let cut = -1;
      for (let i = 0; i < line.length; i++) {
        const c = line[i];
        if (inStr) {
          if (c === '"') inStr = false;
        } else if (c === '"') {
          inStr = true;
        } else if (c === '#' || (c === '/' && line[i + 1] === '/')) {
          cut = i;
          break;
        }
      }
      if (cut >= 0) {
        const code = line.slice(0, cut).replace(/\s+$/, '');
        if (code.trim()) out.push(code);
      } else {
        out.push(line.replace(/\s+$/, ''));
      }
    }
    while (out.length && !out[0].trim()) out.shift();
    while (out.length && !out[out.length - 1].trim()) out.pop();
    return out.join('\n');
  }

  /** Decorate a rendered note/figure *in place* so its leading comments read as hover margin notes —
   * the same affordance code listings get (an accent spine on the element's own box + a corner "✎
   * note" tag that reveals a floating card in the right margin). Decorating in place — rather than
   * adding a padded wrapper — keeps annotated and plain blocks on the same left edge. Returns the
   * element untouched when there's nothing to annotate. */
  function withMarginNote(inner: HTMLElement, annots: string[]): HTMLElement {
    if (annots.length === 0) return inner;
    inner.classList.add('has-note');
    const tag = document.createElement('span');
    tag.className = 'pg-note-tag';
    tag.textContent = annots.length > 1 ? `✎ ${annots.length} notes` : '✎ note';
    inner.appendChild(tag);
    const note = document.createElement('div');
    note.className = 'pg-annot';
    note.innerHTML = annots.map((a) => `<div class="pg-annot-line">${escapeHtml(a)}</div>`).join('');
    inner.appendChild(note);
    return inner;
  }

  /** An emitted note as body prose: KaTeX for a `latex` fence, markdown for `md`, serif
   * preformatted otherwise. */
  function renderPara(b: Extract<Block, { kind: 'note' }>): HTMLElement {
    const el = document.createElement('div');
    el.className = 'pg-para';
    if (b.syntax === 'latex') {
      el.classList.add('pg-latex');
      renderLatex(el, b.text);
    } else if (b.syntax === 'md') {
      el.innerHTML = renderMarkdown(b.text);
    } else {
      el.classList.add('pg-para-plain');
      el.textContent = b.text;
    }
    return el;
  }

  /** Render a `latex`-tagged note: each non-blank line becomes one display-math equation, typeset in
   * the browser with KaTeX. `throwOnError: false` shows a malformed line in red instead of blowing up
   * the whole preview (the interpolated values are already substituted by the engine). */
  function renderLatex(el: HTMLElement, body: string) {
    const lines = body.split('\n').map((l) => l.trim()).filter((l) => l.length > 0);
    for (const line of lines) {
      const row = document.createElement('div');
      row.className = 'pg-latex-eq';
      katex.render(line, row, { displayMode: true, throwOnError: false });
      el.appendChild(row);
    }
  }

  /** A plot as a numbered LaTeX-style figure: framed chart, italic "Figure N." caption with stats. */
  function renderFigure(b: Extract<Block, { kind: 'plot' }>, n: number): HTMLElement {
    const fig = document.createElement('figure');
    fig.className = 'figure pg-figure';
    const frame = document.createElement('div');
    frame.className = 'figure-frame';
    if (b.charts.length > 0) {
      const mount = document.createElement('div');
      mount.className = 'pg-chart';
      frame.appendChild(mount);
      liveCards.push({ mount, charts: b.charts });
      queueMicrotask(() => drawCard(mount, b.charts));
    } else {
      const t = document.createElement('div');
      t.className = 'pg-card-text';
      t.textContent = b.text;
      frame.appendChild(t);
    }
    const cap = document.createElement('figcaption');
    cap.className = 'figure-caption';
    const prefix = `${b.title}: `;
    const detail = b.text.startsWith(prefix) ? b.text.slice(prefix.length) : b.text;
    cap.innerHTML = `<span class="fig-n">Figure ${n}.</span> <span class="pg-fig-title">${escapeHtml(b.title)}</span> — ${escapeHtml(detail)}`;
    fig.append(frame, cap);
    return fig;
  }

  // --- a tiny markdown renderer for `md`-tagged notes (headings, bold/italic, inline code, lists) ---
  function renderMarkdown(src: string): string {
    return src
      .split(/\n{2,}/)
      .map((block) => {
        const b = block.replace(/\s+$/, '');
        const h = b.match(/^(#{1,4})\s+(.*)$/);
        if (h) {
          const lvl = Math.min(6, h[1].length + 2);
          return `<h${lvl} class="pg-md-h">${inlineMd(escapeHtml(h[2]))}</h${lvl}>`;
        }
        const lines = b.split('\n');
        if (lines.length > 0 && lines.every((l) => /^\s*[-*]\s+/.test(l))) {
          const items = lines.map((l) => `<li>${inlineMd(escapeHtml(l.replace(/^\s*[-*]\s+/, '')))}</li>`).join('');
          return `<ul class="pg-md-ul">${items}</ul>`;
        }
        return `<p class="pg-md-p">${inlineMd(escapeHtml(b)).replace(/\n/g, '<br>')}</p>`;
      })
      .join('');
  }
  function inlineMd(s: string): string {
    return s
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
      .replace(/\*([^*]+)\*/g, '<em>$1</em>');
  }

  // The engine readout.
  function renderMetrics(res: NoiseIntrospectResult) {
    const s = res.stats;
    const chips: Array<[string, string, string?]> = [];
    if (s.samples > 0) {
      chips.push(['samples', fmtCount(s.samples)]);
      chips.push(['ops', fmtCount(s.ops)]);
      chips.push(['random', fmtCount(s.rng_draws)]);
    }
    chips.push(['time', fmtMs(res.elapsedMs)]);
    if (s.ops > 0 && res.elapsedMs > 0) {
      chips.push(['ops/sec', fmtCount(Math.round(s.ops / (res.elapsedMs / 1000))), 'm-rate']);
    }
    metricsEl.innerHTML = chips
      .map(
        ([key, val, cls]) =>
          `<span class="pg-metric ${cls ?? ''}"><span class="m-key">${key}</span> ` +
          `<span class="m-val">${val}</span></span>`,
      )
      .join('<span class="m-sep"> · </span>');
    metricsEl.hidden = false;
  }

  function fmtCount(n: number): string {
    if (n < 1000) return String(n);
    const units = ['K', 'M', 'B', 'T'];
    let u = -1;
    let v = n;
    while (v >= 1000 && u < units.length - 1) {
      v /= 1000;
      u++;
    }
    return `${v >= 100 ? v.toFixed(0) : v.toFixed(2)}${units[u]}`;
  }

  function fmtMs(ms: number): string {
    if (ms < 1) return `${ms.toFixed(2)} ms`;
    if (ms < 1000) return `${ms.toFixed(ms < 10 ? 1 : 0)} ms`;
    return `${(ms / 1000).toFixed(2)} s`;
  }

  function escapeHtml(s: string) {
    return s.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]!));
  }

  // --- charts: live mounts so a resized panel re-renders at the new width ---
  const liveCards: { mount: HTMLElement; charts: Plot['charts'] }[] = [];

  async function drawCard(mount: HTMLElement, charts: Plot['charts']) {
    const width = Math.max(240, Math.round(mount.clientWidth));
    try {
      const { renderCharts } = await import('../lib/plot');
      await renderCharts(mount, charts, width);
    } catch (e) {
      mount.innerHTML = `<div class="pg-inspect-err">chart error: ${escapeHtml(String(e))}</div>`;
    }
  }

  let lastWidth = 0;
  let resizeTimer = 0;
  new ResizeObserver(() => {
    window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => {
      const width = outEl.clientWidth;
      if (width === lastWidth || liveCards.length === 0) return;
      lastWidth = width;
      for (const card of liveCards) drawCard(card.mount, card.charts);
    }, 180);
  }).observe(outEl);

  // --- resizable split ---
  const split = $('pg-split');
  const resizer = $('pg-resizer');
  let dragging = false;
  const setLeft = (pct: number) => split.style.setProperty('--pg-left', `${Math.max(25, Math.min(75, pct))}%`);
  resizer.addEventListener('pointerdown', (e) => {
    dragging = true;
    (e.target as HTMLElement).setPointerCapture(e.pointerId);
    document.body.style.userSelect = 'none';
  });
  resizer.addEventListener('pointermove', (e) => {
    if (!dragging) return;
    const rect = split.getBoundingClientRect();
    setLeft(((e.clientX - rect.left) / rect.width) * 100);
  });
  const endDrag = (e: PointerEvent) => {
    if (!dragging) return;
    dragging = false;
    try {
      (e.target as HTMLElement).releasePointerCapture(e.pointerId);
    } catch {}
    document.body.style.userSelect = '';
  };
  resizer.addEventListener('pointerup', endDrag);
  resizer.addEventListener('pointercancel', endDrag);
  // Keyboard: arrow keys nudge the divider.
  resizer.addEventListener('keydown', (e) => {
    const cur = parseFloat(getComputedStyle(split).getPropertyValue('--pg-left')) || 56;
    if (e.key === 'ArrowLeft') setLeft(cur - 3);
    else if (e.key === 'ArrowRight') setLeft(cur + 3);
  });

  // --- layout view switcher (Code / Split / Render) ---
  // `viewPref` / `readView` are declared up top so the fragment carries the view and reloads restore
  // it. The choice is also persisted so it survives a link with no `v=`. On narrow screens a
  // side-by-side split doesn't fit, so `split` resolves to a single pane there while the stored
  // preference is left intact for when the reader is back on a wide screen. There are two copies of
  // the control (one per header row); both are wired here and only one shows per view.
  const narrow = window.matchMedia('(max-width: 880px)');
  const viewTabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.pg-viewtab'));

  // What actually renders: `split` isn't offered on narrow screens, so it resolves to `code` there.
  const effectiveView = (): ViewMode => (narrow.matches && viewPref === 'split' ? 'code' : viewPref);

  function applyView() {
    const eff = effectiveView();
    split.dataset.view = eff;
    for (const btn of viewTabs) btn.setAttribute('aria-pressed', String(btn.dataset.view === eff));
    // Re-fit the editor and any charts now that a pane may have just (dis)appeared.
    editor.layout();
    for (const card of liveCards) drawCard(card.mount, card.charts);
  }

  function setView(v: ViewMode) {
    viewPref = v;
    try { localStorage.setItem(VIEW_KEY, v); } catch {}
    setHash(shareHash());
    applyView();
  }

  for (const btn of viewTabs) {
    btn.addEventListener('click', () => {
      const v = btn.dataset.view;
      if (isViewMode(v)) setView(v);
    });
  }
  // Re-resolve when crossing the narrow/wide boundary (e.g. a phone rotates or a window is resized).
  narrow.addEventListener('change', applyView);
  applyView();

  // --- wiring ---
  $('pg-run').addEventListener('click', execute);
  editor.addCommand(monaco.KeyMod.CtrlCmd | monaco.KeyCode.Enter, execute);

  // --- Share pill: a dropdown with a copy-the-link row + "Download as PDF" ---
  {
    const shareWrap = $('pg-share');
    const shareBtn = $('pg-share-btn') as HTMLButtonElement;
    const shareMenu = $('pg-share-menu');
    const urlBtn = $('pg-share-url') as HTMLButtonElement;
    const urlText = $('pg-share-url-text');
    const copyLabel = $('pg-share-copy');
    const pdfBtn = $('pg-share-pdf') as HTMLButtonElement;
    let copyTimer = 0;

    // The full, shareable URL for the current program (same fragment the live hash carries).
    const shareUrl = () => `${location.origin}${location.pathname}${location.search}${shareHash()}`;

    const openMenu = () => {
      urlText.textContent = shareUrl();
      shareMenu.hidden = false;
      shareBtn.setAttribute('aria-expanded', 'true');
      shareWrap.classList.remove('copied');
      copyLabel.textContent = 'Copy';
    };
    const closeMenu = () => {
      shareMenu.hidden = true;
      shareBtn.setAttribute('aria-expanded', 'false');
    };

    shareBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      shareMenu.hidden ? openMenu() : closeMenu();
    });

    const copyToClipboard = (text: string) => {
      // A hidden-textarea copy always works in a secure, user-gesture context; try the async
      // Clipboard API first and fall back to it. Fire-and-forget so the visual feedback below is
      // never blocked on the promise resolving.
      const fallback = () => {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch {}
        ta.remove();
      };
      try {
        navigator.clipboard?.writeText(text).catch(fallback) ?? fallback();
      } catch {
        fallback();
      }
    };

    urlBtn.addEventListener('click', () => {
      copyToClipboard(shareUrl());
      // Immediate feedback — independent of the clipboard promise so it always shows.
      shareWrap.classList.add('copied');
      copyLabel.textContent = 'Copied';
      window.clearTimeout(copyTimer);
      copyTimer = window.setTimeout(() => {
        shareWrap.classList.remove('copied');
        copyLabel.textContent = 'Copy';
      }, 1600);
    });

    pdfBtn.addEventListener('click', () => {
      closeMenu();
      // Let the menu paint away before the print snapshot is taken.
      window.setTimeout(() => window.print(), 60);
    });

    // Dismiss on an outside click or Escape.
    document.addEventListener('click', (e) => {
      if (!shareMenu.hidden && !shareWrap.contains(e.target as Node)) closeMenu();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !shareMenu.hidden) closeMenu();
    });
  }

  /** Make the selector read the current example when the code matches it verbatim, and "Custom" once
   * the user edits it away (or types a program of their own). */
  function syncSelectToCode() {
    const code = editor.getValue().trim();
    const ex = currentId ? byId.get(currentId) : null;
    select.value = ex && ex.code.trim() === code ? currentId! : CUSTOM_VALUE;
  }

  // Keep the hash live, the header in sync, and the selector label honest as the user edits.
  let hashTimer = 0;
  editor.onDidChangeModelContent(() => {
    window.clearTimeout(hashTimer);
    hashTimer = window.setTimeout(() => {
      setHash(shareHash());
      syncSelectToCode();
      void refreshHeader();
    }, 350);
  });

  window.addEventListener('hashchange', () => {
    if (suppressHash) return;
    loadFromHash();
    applyView(); // an external hash change may carry a different `v=`
  });
</script>
