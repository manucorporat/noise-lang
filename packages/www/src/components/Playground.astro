---
// The interactive playground: a Monaco editor with Noise syntax highlighting, a Run button that
// executes the program through the WASM engine, an output panel, and a category-grouped example
// picker (scales as examples are added). The URL fragment is kept live and shareable as you type
// (#x=<id> for an unmodified example, #c=<encoded> for custom code) — no Share button needed,
// just copy the address bar.
---

<section id="playground" class="playground">
  <div class="pg-grid">
    <div class="pg-editor-wrap glass">
      <div class="pg-toolbar">
        <label class="pg-select-wrap">
          <select id="pg-select" class="pg-select" aria-label="Choose an example"></select>
        </label>
        <button id="pg-run" class="btn btn-run" type="button">
          <span class="btn-icon">▶</span> Run
          <span class="kbd">⌘↵</span>
        </button>
        <button id="pg-reset" class="btn btn-ghost" type="button">Reset</button>
        <span id="pg-status" class="pg-status"></span>
      </div>
      <div id="editor" class="pg-editor"></div>
    </div>

    <aside class="pg-side">
      <div class="pg-explain glass">
        <h3 id="pg-title">Loading…</h3>
        <p id="pg-explanation"></p>
      </div>
      <div class="pg-output-wrap glass">
        <div class="pg-output-head">
          <span class="dot"></span> Output
        </div>
        <div id="pg-output" class="pg-output"><span class="muted">Press Run to evaluate.</span></div>
        <div id="pg-metrics" class="pg-metrics" hidden></div>
      </div>
    </aside>
  </div>
</section>

<style>
  .playground { max-width: none; margin: 0; padding: 0; }

  .pg-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 1rem;
    align-items: stretch;
    /* Grow to use the viewport height when there's room (tall screens), but stay usable on short
       ones and never get so tall the page can't breathe. The editor + output panes flex to fill. */
    min-height: clamp(460px, calc(100vh - 10rem), 900px);
  }
  @media (max-width: 880px) {
    .pg-grid { grid-template-columns: 1fr; min-height: 0; }
  }

  .pg-editor-wrap { display: flex; flex-direction: column; overflow: hidden; }
  .pg-toolbar {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.55rem 0.7rem;
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
    flex-wrap: wrap;
  }
  /* Fill the remaining column height (Monaco's automaticLayout measures the container). min-height:0
     lets the flex child shrink below content size so the toolbar never gets pushed off. */
  .pg-editor { flex: 1; min-height: 0; height: auto; width: 100%; }
  @media (max-width: 880px) { .pg-editor { flex: none; height: 320px; } }

  .pg-select-wrap { position: relative; display: inline-flex; }
  .pg-select {
    appearance: none;
    font: inherit;
    font-size: 0.88rem;
    color: var(--ink);
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 0.4rem 1.8rem 0.4rem 0.7rem;
    cursor: pointer;
    max-width: 230px;
  }
  .pg-select:hover { border-color: var(--accent); }
  .pg-select:focus-visible { outline: 2px solid var(--link); }
  .pg-select-wrap::after {
    content: '▾';
    position: absolute; right: 0.65rem; top: 50%; transform: translateY(-50%);
    pointer-events: none; color: var(--ink-dim); font-size: 0.75rem;
  }

  .btn {
    font: inherit;
    font-size: 0.9rem;
    border-radius: 4px;
    padding: 0.4rem 0.8rem;
    cursor: pointer;
    border: 1px solid var(--rule);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: transform 0.08s ease, background 0.15s ease, color 0.15s ease;
  }
  .btn:active { transform: translateY(1px); }
  .btn-run {
    background: var(--ink);
    color: var(--paper);
    font-weight: 600;
    border-color: var(--ink);
  }
  .btn-run:hover { background: #000; }
  .btn-run[disabled] { opacity: 0.55; cursor: progress; }
  .btn-icon { font-size: 0.7em; }
  .btn-ghost { background: transparent; color: var(--ink-dim); }
  .btn-ghost:hover { color: var(--ink); border-color: var(--accent); }
  .kbd {
    font-size: 0.68rem;
    opacity: 0.65;
    border: 1px solid currentColor;
    border-radius: 4px;
    padding: 0 0.28rem;
  }
  .pg-status { margin-left: auto; font-size: 0.8rem; color: var(--ink-dim); font-style: italic; }

  .pg-side { display: flex; flex-direction: column; gap: 1rem; }
  .pg-explain { padding: 0.95rem 1.05rem; }
  .pg-explain h3 { margin: 0 0 0.45rem; font-size: 1.02rem; color: var(--ink); }
  .pg-explain p { margin: 0; color: var(--ink-dim); font-size: 0.9rem; line-height: 1.5; }

  .pg-output-wrap { flex: 1; display: flex; flex-direction: column; min-height: 150px; overflow: hidden; }
  .pg-output-head {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 0.85rem;
    border-bottom: 1px solid var(--rule);
    font-size: 0.76rem; font-variant: small-caps; letter-spacing: 0.06em; color: var(--ink-dim);
  }
  .pg-output-head .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent); }
  .pg-output {
    margin: 0; padding: 0.85rem; flex: 1; overflow: auto;
    font-family: var(--mono); font-size: 0.86rem; line-height: 1.5;
    color: var(--ink); word-break: break-word;
    background: var(--paper-2);
  }
  /* Output is now a stream: Print lines (.out-text) and plot cards interleaved. */
  .pg-output .out-text { font-family: var(--mono); white-space: pre-wrap; margin: 0; }
  .pg-output .pg-card { margin: 0.55rem 0; background: var(--paper); }
  .pg-output .muted { color: var(--ink-faint); }
  .pg-output .val { color: #9a5b00; font-weight: 700; }
  .pg-output .err { color: #a4262c; }
  .pg-output .label { color: var(--ink-dim); }

  /* Engine readout: a compact strip of stat chips shown after a run that forced sampling. Inline
     flow (not flex) so the " · " separators and intra-chip spaces are real text that wraps and
     copy-pastes as a readable line. */
  .pg-metrics {
    padding: 0.5rem 0.85rem;
    border-top: 1px solid var(--rule);
    background: var(--paper);
    font-family: var(--mono);
    font-size: 0.74rem;
    line-height: 1.7;
    color: var(--ink-dim);
  }
  .pg-metric { white-space: nowrap; }
  .pg-metrics[hidden] { display: none; }
  .pg-metric .m-key { font-variant: small-caps; letter-spacing: 0.04em; color: var(--ink-faint); }
  .pg-metric .m-val { color: var(--ink); font-weight: 700; }
  .pg-metric.m-rate .m-val { color: var(--accent); }
  .m-sep { color: var(--ink-faint); opacity: 0.6; }

  /* --- Result cards (one per `plot::*` item in the output stream) --- */
  .pg-card { border: 1px solid var(--rule); border-radius: 6px; background: var(--paper); padding: 0.6rem 0.7rem; }
  /* The text card: one self-contained line — the same one the CLI prints — with its leading
     `hist(st):` heading emphasized. It is the whole card when there is nothing to draw (a scalar)
     or no renderer, and the chart's caption otherwise. */
  .pg-card-text { font-family: var(--mono); font-size: 0.72rem; color: var(--ink-dim); line-height: 1.5; overflow-wrap: anywhere; }
  .pg-card-title { color: var(--ink); font-weight: 700; }
  /* Charts are sized to this box's measured width; the overflow guard catches a chart that
     nonetheless renders wider (a long axis label) rather than letting the page scroll sideways. */
  .pg-chart { margin-top: 0.4rem; overflow-x: auto; }
  .pg-chart:empty { display: none; }
  .pg-chart .vega-embed { width: 100%; }
  .pg-chart summary { display: none; }
  .pg-inspect-err { font-family: var(--mono); font-size: 0.76rem; color: #a4262c; }

  /* --- Plots panel (program-driven `plot::*` charts) --- */
  .pg-plots-wrap { display: flex; flex-direction: column; overflow: hidden; }
  .dot.dot-3 { background: #9a5b00; }
  #pg-plots { padding: 0.7rem 0.85rem; }
</style>

<script>
  import * as monaco from 'monaco-editor/esm/vs/editor/editor.api';
  import EditorWorker from 'monaco-editor/esm/vs/editor/editor.worker?worker';
  import { registerNoise, LANGUAGE_ID, THEME_ID } from '../lib/noise-lang';
  import { runNoiseWithIntrospection, type NoiseIntrospectResult, type Plot } from '../lib/noise';
  // (LogItem is structural; we read res.log items inline.)
  import { examples, defaultExampleId, examplesByCategory } from '../data/examples';
  import { parseHash, encodeCode } from '../lib/share';

  // Noise has no language service worker; only the base editor worker is needed.
  (self as any).MonacoEnvironment = { getWorker: () => new EditorWorker() };

  const $ = (id: string) => document.getElementById(id)!;
  const titleEl = $('pg-title');
  const explEl = $('pg-explanation');
  const statusEl = $('pg-status');
  const outEl = $('pg-output');
  const metricsEl = $('pg-metrics');
  const select = $('pg-select') as HTMLSelectElement;

  registerNoise(monaco);

  const byId = new Map(examples.map((e) => [e.id, e]));

  // Populate the grouped dropdown.
  for (const group of examplesByCategory()) {
    const og = document.createElement('optgroup');
    og.label = group.category;
    for (const ex of group.items) {
      const opt = document.createElement('option');
      opt.value = ex.id;
      opt.textContent = ex.title;
      og.appendChild(opt);
    }
    select.appendChild(og);
  }

  let currentId: string | null = defaultExampleId;
  let suppressHash = false; // guard so our own hash writes don't re-trigger a load

  const editor = monaco.editor.create($('editor'), {
    value: byId.get(defaultExampleId)?.code ?? examples[0]?.code ?? '',
    language: LANGUAGE_ID,
    theme: THEME_ID,
    fontSize: 14,
    fontFamily: 'ui-monospace, SFMono-Regular, "JetBrains Mono", Menlo, monospace',
    fontLigatures: true,
    minimap: { enabled: false },
    scrollBeyondLastLine: false,
    padding: { top: 14, bottom: 14 },
    lineNumbers: 'on',
    renderLineHighlight: 'line',
    smoothScrolling: true,
    automaticLayout: true,
    scrollbar: { verticalScrollbarSize: 8, horizontalScrollbarSize: 8 },
  });

  function clearOutput() {
    outEl.innerHTML = '<span class="muted">Press Run to evaluate.</span>';
    metricsEl.hidden = true;
    metricsEl.innerHTML = '';
  }

  function setHash(value: string) {
    // replaceState (not location.hash) so live edits don't pollute history or refire a load.
    suppressHash = true;
    history.replaceState(null, '', value);
    setTimeout(() => (suppressHash = false), 0);
  }

  // The shareable fragment for the current state: a clean #x=id when the code is an unmodified
  // example, otherwise a #c= snapshot of the source. Kept live as the user types.
  function shareHash(): string {
    const code = editor.getValue();
    const ex = currentId ? byId.get(currentId) : undefined;
    if (ex && ex.code.trim() === code.trim()) return `#x=${currentId}`;
    return `#c=${encodeCode(code)}`;
  }

  function selectExample(id: string, { loadCode = true, updateHash = true } = {}) {
    const ex = byId.get(id);
    if (!ex) return;
    currentId = id;
    titleEl.textContent = ex.title;
    explEl.textContent = ex.explanation;
    select.value = id;
    if (loadCode) editor.setValue(ex.code);
    if (updateHash) setHash(`#x=${id}`);
    clearOutput();
  }

  function loadCustom(code: string) {
    currentId = null;
    titleEl.textContent = 'Shared program';
    explEl.textContent =
      'A program shared via link. Edit and run it, or pick an example from the menu above.';
    select.selectedIndex = -1;
    editor.setValue(code);
    clearOutput();
  }

  function loadFromHash({ updateHash = false } = {}) {
    const parsed = parseHash(location.hash);
    if (parsed.exampleId && byId.has(parsed.exampleId)) {
      selectExample(parsed.exampleId, { loadCode: true, updateHash });
    } else if (parsed.code !== undefined) {
      loadCustom(parsed.code);
    } else {
      selectExample(defaultExampleId, { loadCode: false, updateHash: false });
    }
  }

  // Initial load: honor a shared fragment if present, else the default example.
  loadFromHash();

  select.addEventListener('change', () => {
    if (select.value) selectExample(select.value);
  });

  async function run() {
    const runBtn = $('pg-run') as HTMLButtonElement;
    runBtn.disabled = true;
    statusEl.textContent = 'running…';
    outEl.innerHTML = '<span class="muted">running…</span>';
    metricsEl.hidden = true;
    try {
      const res = await runNoiseWithIntrospection(editor.getValue(), []);
      statusEl.textContent = `done in ${fmtMs(res.elapsedMs)}`;
      renderResult(res);
      renderMetrics(res);
    } catch (e) {
      statusEl.textContent = 'error';
      outEl.innerHTML = `<span class="err">${escapeHtml(String(e))}</span>`;
    } finally {
      runBtn.disabled = false;
    }
  }

  function renderResult(res: NoiseIntrospectResult) {
    outEl.innerHTML = '';
    liveCards.length = 0;
    const addText = (html: string, cls = 'out-text') => {
      const el = document.createElement('div');
      el.className = cls;
      el.innerHTML = html;
      outEl.appendChild(el);
    };
    // The output stream: Print lines and plot:: charts, interleaved in source order.
    for (const item of res.log) {
      if (item.kind === 'text') addText(escapeHtml(item.text));
      else outEl.appendChild(renderCard(item));
    }
    if (res.ok) {
      if (res.value !== null) {
        addText(`<span class="label">⇒ </span><span class="val">${escapeHtml(res.value)}</span>`);
      } else if (res.log.length === 0) {
        addText('<span class="muted">(no output)</span>');
      }
    } else {
      addText(escapeHtml(res.error ?? 'error'), 'out-text err');
    }
  }

  // The engine readout. Most programs force some Monte-Carlo sampling (P/E/Var/Q); for those we show
  // what was computed and how fast. A purely deterministic program forces nothing — we then show
  // just the time, since "0 ops" would be misleading (the work was the deterministic eval, untimed).
  function renderMetrics(res: NoiseIntrospectResult) {
    const s = res.stats;
    const chips: Array<[string, string, string?]> = [];
    if (s.samples > 0) {
      chips.push(['samples', fmtCount(s.samples)]);
      chips.push(['ops', fmtCount(s.ops)]);
      chips.push(['random', fmtCount(s.rng_draws)]);
    }
    chips.push(['time', fmtMs(res.elapsedMs)]);
    // ops/sec only makes sense when both an op count and a measurable time exist. The label already
    // says "/sec", so the value is a bare count (no redundant "/s" suffix).
    if (s.ops > 0 && res.elapsedMs > 0) {
      chips.push(['ops/sec', fmtCount(Math.round(s.ops / (res.elapsedMs / 1000))), 'm-rate']);
    }
    // Real text nodes for the space and separator (not just flex gap) so the line copy-pastes
    // readably: "samples 1.00M · ops 8.00M · …".
    metricsEl.innerHTML = chips
      .map(
        ([key, val, cls]) =>
          `<span class="pg-metric ${cls ?? ''}"><span class="m-key">${key}</span> ` +
          `<span class="m-val">${val}</span></span>`,
      )
      .join('<span class="m-sep"> · </span>');
    metricsEl.hidden = false;
  }

  // Compact SI-ish formatting: 1_234_567 → "1.23M", so the strip stays scannable at a glance.
  function fmtCount(n: number): string {
    if (n < 1000) return String(n);
    const units = ['K', 'M', 'B', 'T'];
    let u = -1;
    let v = n;
    while (v >= 1000 && u < units.length - 1) {
      v /= 1000;
      u++;
    }
    return `${v >= 100 ? v.toFixed(0) : v.toFixed(2)}${units[u]}`;
  }

  function fmtMs(ms: number): string {
    if (ms < 1) return `${ms.toFixed(2)} ms`;
    if (ms < 1000) return `${ms.toFixed(ms < 10 ? 1 : 0)} ms`;
    return `${(ms / 1000).toFixed(2)} s`;
  }

  function escapeHtml(s: string) {
    return s.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]!));
  }

  // --- Result cards: one per `plot::*` item in the output stream ---
  //
  // There is one card renderer, not one per chart kind. The engine ships a `Plot` — a title, a
  // one-line text card, and zero or more Flint chart specs — and `../lib/plot` compiles them. Both
  // streams (the program's own `plot::*` calls and the introspection sidecar) come through here.

  /** Live plot cards, so a resized output panel re-renders its charts at the new width. */
  const liveCards: { mount: HTMLElement; charts: Plot['charts'] }[] = [];

  // A plot's `text` is one self-contained line — `"hist(st): n=… mean=…"` — exactly what the CLI
  // prints. The card shows that same line, with the leading heading emphasized rather than repeated
  // on a row of its own.
  function headline(plot: Plot): string {
    const prefix = `${plot.title}: `;
    if (!plot.text.startsWith(prefix)) return escapeHtml(plot.text);
    const detail = plot.text.slice(prefix.length);
    return `<span class="pg-card-title">${escapeHtml(plot.title)}</span>: ${escapeHtml(detail)}`;
  }

  function renderCard(plot: Plot): HTMLElement {
    const el = document.createElement('div');
    el.className = 'pg-card';
    const cls = plot.error ? 'pg-inspect-err' : 'pg-card-text';
    el.innerHTML = `<div class="${cls}">${headline(plot)}</div>`;
    if (plot.charts.length === 0) return el;

    const mount = document.createElement('div');
    mount.className = 'pg-chart';
    el.appendChild(mount);
    liveCards.push({ mount, charts: plot.charts });
    // Deferred: the card must be in the document before its width can be measured.
    queueMicrotask(() => drawCard(mount, plot.charts));
    return el;
  }

  /** Compile + embed a card's charts at its current width. A failure leaves the text card standing. */
  async function drawCard(mount: HTMLElement, charts: Plot['charts']) {
    const width = Math.max(240, Math.round(mount.clientWidth));
    try {
      const { renderCharts } = await import('../lib/plot');
      await renderCharts(mount, charts, width);
    } catch (e) {
      mount.innerHTML = `<div class="pg-inspect-err">chart error: ${escapeHtml(String(e))}</div>`;
    }
  }

  // Charts are rendered at a fixed pixel width, so a resized panel needs them redrawn. Debounced,
  // and skipped while the width is unchanged (a height-only resize must not re-embed every chart).
  let lastWidth = 0;
  let resizeTimer = 0;
  new ResizeObserver(() => {
    window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => {
      const width = outEl.clientWidth;
      if (width === lastWidth || liveCards.length === 0) return;
      lastWidth = width;
      for (const card of liveCards) drawCard(card.mount, card.charts);
    }, 180);
  }).observe(outEl);

  $('pg-run').addEventListener('click', run);
  $('pg-reset').addEventListener('click', () => {
    if (currentId) selectExample(currentId, { loadCode: true, updateHash: false });
  });
  editor.addCommand(monaco.KeyMod.CtrlCmd | monaco.KeyCode.Enter, run);

  // Keep the URL fragment live as the user edits, so the address bar is always a shareable link
  // (debounced; replaceState keeps it out of history).
  let hashTimer = 0;
  editor.onDidChangeModelContent(() => {
    window.clearTimeout(hashTimer);
    hashTimer = window.setTimeout(() => setHash(shareHash()), 350);
  });

  // React to back/forward or a pasted link changing the hash (ignore our own writes).
  window.addEventListener('hashchange', () => {
    if (!suppressHash) loadFromHash();
  });
</script>
