---
// Demo §5 (flagship): AM vs FM as a scrollytelling explainer. A sticky stage (WebGL phasor view +
// the program) stays pinned while five steps scroll past; each step reveals more code and changes
// the visualization. The carrier is a phasor — one complex number per instant: AM writes the
// message into its length, FM into its angle (Euler's e^{iθ}) — so the same static smears AM's
// radius but barely moves FM's angle. The whole chain stays in signal land (PLAN-SIGNALS): the
// message is a lazy waveform, the static is ONE `~`-drawn realization shared by both carriers,
// and mse renders everything at the ambient resolution. The real engine confirms the MSE at the
// end. Code shown == code run.
import CodePanel from './CodePanel.astro';

const code = `engine::set_resolution(64);

msg = 0.3 * signal::sine(3);

am = 1 + msg;
fm = math::exp(math::i * 3 * msg);

static ~ signal::noise_white_complex(0.4);
rx_am = am + static;
rx_fm = fm + static;

rec_am = math::abs(rx_am) - 1;
rec_fm = math::arg(rx_fm) / 3;

Print("AM error", E(vec::mse(rec_am, msg), 40000));
Print("FM error", E(vec::mse(rec_fm, msg), 40000));`;
---

<div class="amfm scrolly">
  <div class="scrolly-grid">
    <div class="scrolly-stage">
      <div class="stage-inner glass">
        <h4 class="stage-title">AM vs FM</h4>
        <div class="amfm-canvas-wrap"><canvas id="amfm-canvas" aria-label="AM vs FM phasor visualization"></canvas></div>
        <CodePanel filename="am_fm.noise" code={code} class="amfm-code" />
        <p class="amfm-engine" id="amfm-engine">scroll through the steps →</p>
      </div>
      <figcaption class="figure-caption">
        <span class="fig-n">Figure 5.</span> AM vs FM, end to end. The carrier is a phasor; AM rides its
        length, FM its angle. The same static corrupts the length but spares the angle — which is why FM
        shrugs off noise. Numbers from the real engine.
      </figcaption>
    </div>
    <div class="scrolly-steps" id="amfm-steps">
      <div class="scrolly-step" data-step="0">
        <h4>The message</h4>
        <p>A gentle tone — <code class="code-inline">sine(3)</code> is a <em>waveform</em>, not samples. No length appears in the math; the one resolution setting sits at the top, next to the measurement. This is what we want to send through a noisy channel and get back intact.</p>
      </div>
      <div class="scrolly-step" data-step="1">
        <h4>AM — message in the amplitude</h4>
        <p>The carrier is a phasor — a spinning arrow, one complex number per instant. <strong>AM</strong> puts the message in its <em>length</em>: the tip slides in and out, crossing the unit circle as the message rises and falls.</p>
      </div>
      <div class="scrolly-step" data-step="2">
        <h4>FM — message in the angle</h4>
        <p><strong>FM</strong> instead puts the message in the <em>angle</em>, via Euler's <code class="code-inline">e^(i·θ)</code>: the tip rides the unit circle while its length stays fixed. Same information, encoded in rotation rather than reach.</p>
      </div>
      <div class="scrolly-step" data-step="3">
        <h4>Add the same static</h4>
        <p><code class="code-inline">~</code> draws ONE realization of complex noise — every mention of <code class="code-inline">static</code> is the <em>same</em> static, so both carriers face an identical storm by construction. It smears AM along the <em>radius</em> it reads from — but only nudges FM <em>around</em> the circle. Watch the clouds.</p>
      </div>
      <div class="scrolly-step" data-step="4">
        <h4>Demodulate &amp; compare</h4>
        <p>Read the length back for AM, the angle for FM. Side by side — the demodulated AM on the left, FM on the right, the original tone in ink over each — the same static visibly rattles AM while FM hugs the message. That's the payoff of spending bandwidth on the angle.</p>
      </div>
    </div>
  </div>
</div>

<style>
  /* layout is the shared .scrolly-* scaffold; only the canvas + code chrome are demo-specific */
  .amfm-canvas-wrap { width: 100%; height: 150px; background: #f4f1e8; border: 1px solid var(--rule); border-radius: 4px; overflow: hidden; }
  #amfm-canvas { width: 100%; height: 100%; display: block; }
  /* this demo's program is the longest (16 lines), so nudge its code a touch smaller + tighter
     to fit without an inner scrollbar */
  :global(.amfm-code .code-body) { font-size: 0.9rem; line-height: 1.45; padding: 0.7rem 1rem; }
  .amfm-engine { margin: 0; font-size: 0.84rem; color: var(--ink-dim); min-height: 1.2em; font-family: var(--mono); }
  .amfm-engine .ok { color: #1f6f8b; font-weight: 700; }
  .amfm-engine .am { color: #8a2d4a; font-weight: 700; }
</style>

<script>
  import { runNoise, engineMetrics } from '../lib/noise';

  const canvas = document.getElementById('amfm-canvas') as HTMLCanvasElement | null;
  const stepsEl = document.getElementById('amfm-steps');
  const engineEl = document.getElementById('amfm-engine')!;
  const codeBody = document.querySelector('.amfm .code-body') as HTMLElement | null;

  const STEPS = [
    { show: 2, add: [0, 2], mode: 'msg' },
    { show: 4, add: [4], mode: 'am' },
    { show: 5, add: [5], mode: 'fm' },
    { show: 9, add: [7, 8, 9], mode: 'noise' },
    { show: 15, add: [11, 12, 14, 15], mode: 'compare' },
  ];

  // --- progressive code reveal ---
  if (codeBody) {
    codeBody.classList.add('progressive');
    const lines = Array.from(codeBody.querySelectorAll<HTMLElement>('.cl'));
    (window as any).__amfmReveal = (step: number) => {
      const cfg = STEPS[step];
      lines.forEach((el, i) => {
        el.classList.toggle('shown', i <= cfg.show);
        el.classList.toggle('added', cfg.add.includes(i));
      });
    };
  }

  let mode = 'msg';
  let engineDone = false;

  function setStep(step: number) {
    mode = STEPS[step].mode;
    (window as any).__amfmReveal?.(step);
    for (const el of stepsEl?.querySelectorAll('.scrolly-step') ?? [])
      el.classList.toggle('active', Number((el as HTMLElement).dataset.step) === step);
    if (step === STEPS.length - 1 && !engineDone) { engineDone = true; engineResult(); }
  }

  if (canvas) {
    const gl = canvas.getContext('webgl', { antialias: true, alpha: false });
    if (gl && stepsEl) {
      const N = 64, DEV = 3;
      const msg: number[] = [];
      for (let k = 0; k < N; k++) msg.push(0.3 * Math.sin((2 * Math.PI * 3 * k) / N));

      // gaussian noise via Box–Muller
      const gauss = () => {
        let u = 0, v = 0;
        while (u === 0) u = Math.random();
        while (v === 0) v = Math.random();
        return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v);
      };
      // per-quadrature strength of the complex static: |z|² totals SIGMA_TOTAL², split re/im
      const SIGMA = 0.4 / Math.SQRT2;
      let n1: number[] = [], n2: number[] = [];
      const regen = () => { n1 = msg.map(() => SIGMA * gauss()); n2 = msg.map(() => SIGMA * gauss()); };
      regen();

      const trV = `attribute vec2 p; void main(){ gl_Position=vec4(p,0.0,1.0); }`;
      const trF = `precision highp float; uniform vec3 u_col; void main(){ gl_FragColor=vec4(u_col,1.0); }`;
      const ptV = `attribute vec2 p; uniform float u_size; void main(){ gl_Position=vec4(p,0.0,1.0); gl_PointSize=u_size; }`;
      const ptF = `precision highp float; uniform vec3 u_col; void main(){ vec2 d=gl_PointCoord-0.5; if(dot(d,d)>0.25) discard; gl_FragColor=vec4(u_col,1.0); }`;
      const sh = (t: number, s: string) => { const x = gl.createShader(t)!; gl.shaderSource(x, s); gl.compileShader(x); return x; };
      const mk = (v: string, f: string) => { const p = gl.createProgram()!; gl.attachShader(p, sh(gl.VERTEX_SHADER, v)); gl.attachShader(p, sh(gl.FRAGMENT_SHADER, f)); gl.linkProgram(p); return p; };
      const trP = mk(trV, trF), ptP = mk(ptV, ptF);
      const buf = gl.createBuffer();

      let W = 16, H = 9;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const resize = () => {
        const r = canvas.getBoundingClientRect();
        W = Math.max(1, Math.floor(r.width * dpr)); H = Math.max(1, Math.floor(r.height * dpr));
        canvas.width = W; canvas.height = H; gl.viewport(0, 0, W, H);
      };
      new ResizeObserver(resize).observe(canvas);
      const aspect = () => W / H; // x is wider; scale x by 1/aspect to keep planes circular

      function tris(verts: number[], col: [number, number, number]) {
        if (!verts.length) return;
        gl.useProgram(trP); gl.bindBuffer(gl.ARRAY_BUFFER, buf);
        gl.bufferData(gl.ARRAY_BUFFER, new Float32Array(verts), gl.DYNAMIC_DRAW);
        const a = gl.getAttribLocation(trP, 'p'); gl.enableVertexAttribArray(a); gl.vertexAttribPointer(a, 2, gl.FLOAT, false, 0, 0);
        gl.uniform3f(gl.getUniformLocation(trP, 'u_col'), col[0], col[1], col[2]);
        gl.drawArrays(gl.TRIANGLES, 0, verts.length / 2);
      }
      function pts(verts: number[], size: number, col: [number, number, number]) {
        if (!verts.length) return;
        gl.useProgram(ptP); gl.bindBuffer(gl.ARRAY_BUFFER, buf);
        gl.bufferData(gl.ARRAY_BUFFER, new Float32Array(verts), gl.DYNAMIC_DRAW);
        const a = gl.getAttribLocation(ptP, 'p'); gl.enableVertexAttribArray(a); gl.vertexAttribPointer(a, 2, gl.FLOAT, false, 0, 0);
        gl.uniform1f(gl.getUniformLocation(ptP, 'u_size'), size * dpr);
        gl.uniform3f(gl.getUniformLocation(ptP, 'u_col'), col[0], col[1], col[2]);
        gl.drawArrays(gl.POINTS, 0, verts.length / 2);
      }
      // thin polyline from [x,y,...] pairs. `wd` is the half-thickness in clip-Y units; the
      // normal is computed in aspect-normalized space so the thickness is uniform in pixels
      // regardless of segment slope (otherwise steep/jagged segments balloon on a wide canvas).
      function line(pairs: number[][], wd: number, col: [number, number, number]) {
        const ax = aspect();
        const v: number[] = [];
        for (let i = 0; i < pairs.length - 1; i++) {
          const [x0, y0] = pairs[i], [x1, y1] = pairs[i + 1];
          let dx = (x1 - x0) * ax, dy = y1 - y0; const L = Math.hypot(dx, dy) || 1; dx /= L; dy /= L;
          const nx = (-dy * wd) / ax, ny = dx * wd;
          v.push(x0 + nx, y0 + ny, x1 + nx, y1 + ny, x1 - nx, y1 - ny, x0 + nx, y0 + ny, x1 - nx, y1 - ny, x0 - nx, y0 - ny);
        }
        tris(v, col);
      }

      const INK: [number, number, number] = [0.42, 0.40, 0.36];
      const TEAL: [number, number, number] = [0.12, 0.43, 0.55];
      const MAROON: [number, number, number] = [0.54, 0.18, 0.29];
      const FAINT: [number, number, number] = [0.78, 0.75, 0.69];

      // I/Q plane: map (I,Q) to screen around center cx,cy with scale s (corrected for aspect)
      function P(cx: number, cy: number, s: number, I: number, Q: number): [number, number] {
        return [cx + (I * s) / aspect(), cy + Q * s];
      }
      function ring(cx: number, cy: number, s: number, col: [number, number, number]) {
        const pairs: number[][] = [];
        for (let a = 0; a <= 48; a++) { const t = (a / 48) * Math.PI * 2; pairs.push(P(cx, cy, s, Math.cos(t), Math.sin(t))); }
        line(pairs, 0.004, col);
      }
      function axes(cx: number, cy: number, s: number) {
        line([P(cx, cy, s, -1.4, 0), P(cx, cy, s, 1.4, 0)], 0.003, FAINT);
        line([P(cx, cy, s, 0, -1.4), P(cx, cy, s, 0, 1.4)], 0.003, FAINT);
      }

      let phase = 0, frame = 0;

      const tipIQ = (kind: 'am' | 'fm', m: number): [number, number] =>
        kind === 'am' ? [1 + m, 0] : [Math.cos(DEV * m), Math.sin(DEV * m)];

      function drawPlane(cx: number, kind: 'am' | 'fm', noisy: boolean) {
        const s = 0.6;
        axes(cx, 0, s);
        // faint reference unit circle for BOTH planes, so AM's changing length reads against it
        ring(cx, 0, s, [0.86, 0.84, 0.79]);
        const col = kind === 'am' ? MAROON : TEAL;
        const faint: [number, number, number] = kind === 'am' ? [0.82, 0.66, 0.71] : [0.62, 0.79, 0.84];
        // faint locus = the whole path the tip travels (a segment for AM, an arc for FM)
        const locus: number[][] = [];
        for (let k = 0; k < N; k++) { const [I, Q] = tipIQ(kind, msg[k]); locus.push(P(cx, 0, s, I, Q)); }
        line(locus, 0.005, faint);
        if (noisy) {
          const cloud: number[] = [];
          for (let k = 0; k < N; k++) { const [I0, Q0] = tipIQ(kind, msg[k]); const p = P(cx, 0, s, I0 + n1[k], Q0 + n2[k]); cloud.push(p[0], p[1]); }
          pts(cloud, 3.0, col);
        }
        // a single prominent tip that sweeps smoothly through the samples — the visible motion
        const t = phase % N, k = Math.floor(t), f = t - k;
        const m = msg[k] + (msg[(k + 1) % N] - msg[k]) * f;
        const [I, Q] = tipIQ(kind, m);
        line([P(cx, 0, s, 0, 0), P(cx, 0, s, I, Q)], 0.008, col); // arrow
        const tp = P(cx, 0, s, I, Q);
        pts([tp[0], tp[1]], 10, col); // moving tip dot
      }

      // draw `values` as a waveform across the clip-x range [x0, x1] (so panels can sit side by side)
      function waveform(values: number[], x0: number, x1: number, yc: number, ys: number, col: [number, number, number], wd: number) {
        const pairs: number[][] = [];
        for (let k = 0; k < values.length; k++) {
          const x = x0 + (k / (values.length - 1)) * (x1 - x0);
          pairs.push([x, yc + values[k] * ys]);
        }
        line(pairs, wd, col);
      }

      function draw() {
        gl.clearColor(0.957, 0.945, 0.91, 1); gl.clear(gl.COLOR_BUFFER_BIT);
        if (mode === 'msg') {
          line([[-0.92, 0], [0.92, 0]], 0.002, FAINT);
          waveform(msg, -0.9, 0.9, 0, 2.4, INK, 0.005);
        } else if (mode === 'am') {
          drawPlane(0, 'am', false);
        } else if (mode === 'fm') {
          drawPlane(0, 'fm', false);
        } else if (mode === 'noise') {
          drawPlane(-0.5, 'am', true);
          drawPlane(0.5, 'fm', true);
        } else if (mode === 'compare') {
          const recAm = msg.map((m, k) => Math.sqrt((1 + m + n1[k]) ** 2 + n2[k] ** 2) - 1);
          const recFm = msg.map((m, k) => Math.atan((Math.sin(DEV * m) + n2[k]) / (Math.cos(DEV * m) + n1[k])) / DEV);
          // side by side — AM left, FM right, the original tone in ink over each — so the
          // rattle vs. hug reads at a glance instead of three overlaid curves
          line([[-0.95, 0], [-0.05, 0]], 0.002, FAINT);
          line([[0.05, 0], [0.95, 0]], 0.002, FAINT);
          line([[0, -0.85], [0, 0.85]], 0.002, FAINT); // panel divider
          waveform(recAm, -0.95, -0.05, 0, 2.4, MAROON, 0.0035); // AM (noisy)
          waveform(msg, -0.95, -0.05, 0, 2.4, INK, 0.005);       // original on top
          waveform(recFm, 0.05, 0.95, 0, 2.4, TEAL, 0.0035);     // FM (clean)
          waveform(msg, 0.05, 0.95, 0, 2.4, INK, 0.005);         // original on top
        }
      }

      function loop() {
        frame++;
        phase += 0.35;
        if ((mode === 'noise' || mode === 'compare') && frame % 5 === 0) regen();
        draw();
        requestAnimationFrame(loop);
      }
      resize(); loop();

      // step observer
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting && e.intersectionRatio > 0.5) setStep(Number((e.target as HTMLElement).dataset.step));
        }
      }, { threshold: [0.5, 0.75], rootMargin: '-20% 0px -20% 0px' });
      for (const el of stepsEl.querySelectorAll('.scrolly-step')) io.observe(el);

      setStep(0);
    }
  }

  async function engineResult() {
    engineEl.textContent = 'running the engine (40k noise realizations)…';
    try {
      const src = `engine::set_resolution(64);
msg = 0.3 * signal::sine(3);
am = 1 + msg;
fm = math::exp(math::i * 3 * msg);
static ~ signal::noise_white_complex(0.4);
rx_am = am + static;
rx_fm = fm + static;
rec_am = math::abs(rx_am) - 1;
rec_fm = math::arg(rx_fm) / 3;
Print("AM", E(vec::mse(rec_am, msg), 40000));
Print("FM", E(vec::mse(rec_fm, msg), 40000));`;
      const res = await runNoise(src);
      const out = res.output.trim().split('\n');
      const am = (out.find((l) => l.startsWith('AM')) ?? '').replace('AM', '').trim();
      const fm = (out.find((l) => l.startsWith('FM')) ?? '').replace('FM', '').trim();
      engineEl.innerHTML = `engine: AM error <span class="am">${am}</span> · FM error <span class="ok">${fm}</span> — ${engineMetrics(res)}`;
    } catch { engineEl.textContent = ''; }
  }
</script>
