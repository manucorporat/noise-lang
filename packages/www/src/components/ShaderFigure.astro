---
// The "noise" namesake as a LaTeX-style figure: an animated fractal-noise field rendered as
// ink contour lines on paper, interactive with the cursor. Contained (not a full-bleed
// background), captioned like a figure in a paper.
interface Props { caption?: string; n?: number; install?: string }
const {
  caption = 'a fractal-noise field — move your cursor to disturb it.',
  n = 1, // pass n={0} to drop the "Figure N." label (e.g. outside the paper figure flow)
  install,
} = Astro.props;
// The pill offers every way to get Noise, switched by a small dropdown. A page-specific
// `install` command (e.g. the skill page's `npx skills add …`) becomes the first, default entry.
const STANDARD_MODES = [
  { label: 'CLI', cmd: 'cargo install noise-cli' },
  { label: 'Web', cmd: 'npm install @noiselang/core' },
];
const modes = install ? [{ label: 'Agent', cmd: install }, ...STANDARD_MODES] : STANDARD_MODES;
---

<figure class="figure shader-fig">
  <div class="figure-frame">
    <canvas id="noise-fig" aria-hidden="true"></canvas>
    <div class="install-overlay">
      <div class="install-pill">
        <span class="install-mode">
          <select class="install-select" aria-label="Choose an install target">
            {modes.map((m) => <option value={m.cmd}>{m.label}</option>)}
          </select>
        </span>
        <button
          class="install-copy-btn"
          type="button"
          data-install={modes[0].cmd}
          aria-label={`Copy install command: ${modes[0].cmd}`}
        >
          <span class="install-prompt" aria-hidden="true">$</span>
          <code class="install-cmd">{modes[0].cmd}</code>
          <span class="install-copy" aria-hidden="true">
            <svg class="ic-copy" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <svg class="ic-check" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <span class="install-copied" aria-hidden="true">Copied</span>
        </button>
      </div>
    </div>
  </div>
  {(n || caption) && (
    <figcaption class="figure-caption">
      {n ? <span class="fig-n">Figure {n}.</span> : null} {caption}
    </figcaption>
  )}
</figure>

<style>
  .shader-fig { margin-top: 1.5rem; margin-bottom: 0; }
  .shader-fig .figure-frame { background: #f4f1e8; position: relative; }
  #noise-fig { display: block; width: 100%; height: 320px; cursor: crosshair; }
  @media (max-width: 720px) { #noise-fig { height: 220px; } }

  /* the install command, floating over the noise field */
  .install-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none; /* let the cursor disturb the field everywhere except the pill */
    padding: 1rem;
  }
  .install-pill {
    pointer-events: auto;
    display: inline-flex;
    align-items: stretch;
    margin: 0;
    padding: 0;
    font-family: var(--mono);
    font-size: 0.95rem;
    line-height: 1;
    color: var(--ink);
    border: 1px solid rgba(27, 26, 23, 0.14);
    border-radius: 8px;
    background: rgba(251, 250, 246, 0.82);
    -webkit-backdrop-filter: blur(7px) saturate(1.1);
    backdrop-filter: blur(7px) saturate(1.1);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 8px 24px -10px rgba(27, 26, 23, 0.4),
      0 1.5px 5px -2px rgba(27, 26, 23, 0.25);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, background 0.18s ease;
  }
  .install-pill:hover {
    transform: translateY(-1px);
    border-color: rgba(27, 26, 23, 0.24);
    background: rgba(251, 250, 246, 0.92);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.7) inset,
      0 12px 30px -10px rgba(27, 26, 23, 0.45),
      0 2px 6px -2px rgba(27, 26, 23, 0.3);
  }
  .install-pill:active { transform: translateY(0); }

  /* the install-target dropdown — a quiet segment attached to the pill's left edge */
  .install-mode {
    position: relative;
    display: flex;
    align-items: center;
    border-right: 1px solid rgba(27, 26, 23, 0.12);
  }
  .install-mode::after {
    content: '▾';
    position: absolute;
    right: 0.55rem;
    pointer-events: none;
    font-size: 0.68rem;
    color: var(--ink-dim);
  }
  .install-select {
    appearance: none;
    -webkit-appearance: none;
    border: none;
    background: transparent;
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--ink-dim);
    padding: 0.62rem 1.35rem 0.62rem 0.85rem;
    cursor: pointer;
    border-radius: 8px 0 0 8px;
    transition: color 0.15s ease;
  }
  .install-select:hover { color: var(--ink); }
  .install-select:focus-visible { outline: 2px solid var(--accent); outline-offset: -2px; }

  /* the command + copy affordance (the clickable part) */
  .install-copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    margin: 0;
    padding: 0.62rem 0.85rem 0.62rem 0.9rem;
    font-family: inherit;
    font-size: inherit;
    line-height: 1;
    color: inherit;
    cursor: pointer;
    border: none;
    background: transparent;
    border-radius: 0 8px 8px 0;
  }
  .install-copy-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: -2px; }

  .install-prompt { color: var(--accent); font-weight: 700; user-select: none; }
  .install-cmd { font-family: var(--mono); font-size: inherit; color: var(--ink); white-space: nowrap; }

  .install-copy {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.55rem;
    height: 1.55rem;
    margin-left: 0.15rem;
    border-radius: 5px;
    color: var(--ink-dim);
    background: rgba(27, 26, 23, 0.05);
    transition: color 0.18s ease, background 0.18s ease;
  }
  .install-pill:hover .install-copy { color: var(--ink); background: rgba(27, 26, 23, 0.09); }
  .install-copy .ic-check { display: none; }

  /* the "Copied" confirmation slides in over the icon */
  .install-copied {
    font-family: var(--mono);
    font-size: 0.82rem;
    font-weight: 500;
    color: #1f6f8b;
    white-space: nowrap;
    width: 0;
    overflow: hidden;
    opacity: 0;
    transition: width 0.2s ease, opacity 0.2s ease;
  }
  .install-pill.copied .install-copy { color: #1f6f8b; background: rgba(31, 111, 139, 0.12); }
  .install-pill.copied .install-copy .ic-copy { display: none; }
  .install-pill.copied .install-copy .ic-check { display: inline; }
  .install-pill.copied .install-copied { width: 3.4rem; opacity: 1; }

  @media (max-width: 720px) {
    .install-pill { font-size: 0.85rem; }
    .install-copy-btn { padding: 0.55rem 0.7rem 0.55rem 0.75rem; gap: 0.5rem; }
    .install-select { font-size: 0.76rem; padding: 0.55rem 1.2rem 0.55rem 0.7rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .install-pill, .install-copied, .install-copy { transition: none; }
  }
</style>

<script>
  const canvas = document.getElementById('noise-fig') as HTMLCanvasElement | null;
  if (canvas) {
    const gl = canvas.getContext('webgl', { antialias: true, alpha: false });
    if (gl) {
      const vert = `attribute vec2 p; void main(){ gl_Position = vec4(p,0.0,1.0); }`;

      // Simplex noise (Ashima/webgl-noise 3D) + fbm, shaded as ink contour lines on paper.
      const frag = `
        precision highp float;
        uniform vec2  u_res;
        uniform float u_time;
        uniform vec2  u_mouse;

        vec4 permute(vec4 x){ return mod(((x*34.0)+1.0)*x, 289.0); }
        vec4 taylorInvSqrt(vec4 r){ return 1.79284291400159 - 0.85373472095314 * r; }
        float snoise(vec3 v){
          const vec2 C = vec2(1.0/6.0, 1.0/3.0); const vec4 D = vec4(0.0,0.5,1.0,2.0);
          vec3 i = floor(v + dot(v, C.yyy)); vec3 x0 = v - i + dot(i, C.xxx);
          vec3 g = step(x0.yzx, x0.xyz); vec3 l = 1.0 - g;
          vec3 i1 = min(g.xyz, l.zxy); vec3 i2 = max(g.xyz, l.zxy);
          vec3 x1 = x0 - i1 + C.xxx; vec3 x2 = x0 - i2 + 2.0*C.xxx; vec3 x3 = x0 - 1.0 + 3.0*C.xxx;
          i = mod(i, 289.0);
          vec4 pp = permute(permute(permute(
            i.z + vec4(0.0, i1.z, i2.z, 1.0)) + i.y + vec4(0.0, i1.y, i2.y, 1.0))
            + i.x + vec4(0.0, i1.x, i2.x, 1.0));
          float n_ = 1.0/7.0; vec3 ns = n_ * D.wyz - D.xzx;
          vec4 j = pp - 49.0 * floor(pp * ns.z * ns.z);
          vec4 x_ = floor(j * ns.z); vec4 y_ = floor(j - 7.0 * x_);
          vec4 x = x_*ns.x + ns.yyyy; vec4 y = y_*ns.x + ns.yyyy; vec4 h = 1.0 - abs(x) - abs(y);
          vec4 b0 = vec4(x.xy, y.xy); vec4 b1 = vec4(x.zw, y.zw);
          vec4 s0 = floor(b0)*2.0+1.0; vec4 s1 = floor(b1)*2.0+1.0; vec4 sh = -step(h, vec4(0.0));
          vec4 a0 = b0.xzyw + s0.xzyw*sh.xxyy; vec4 a1 = b1.xzyw + s1.xzyw*sh.zzww;
          vec3 p0 = vec3(a0.xy,h.x); vec3 p1 = vec3(a0.zw,h.y); vec3 p2 = vec3(a1.xy,h.z); vec3 p3 = vec3(a1.zw,h.w);
          vec4 norm = taylorInvSqrt(vec4(dot(p0,p0), dot(p1,p1), dot(p2,p2), dot(p3,p3)));
          p0*=norm.x; p1*=norm.y; p2*=norm.z; p3*=norm.w;
          vec4 m = max(0.6 - vec4(dot(x0,x0), dot(x1,x1), dot(x2,x2), dot(x3,x3)), 0.0); m = m*m;
          return 42.0 * dot(m*m, vec4(dot(p0,x0), dot(p1,x1), dot(p2,x2), dot(p3,x3)));
        }
        float fbm(vec3 p){ float f=0.0,a=0.5; for(int i=0;i<5;i++){ f+=a*snoise(p); p*=2.03; a*=0.5; } return f; }

        void main(){
          vec2 uv = (gl_FragCoord.xy - 0.5*u_res) / u_res.y;
          float t = u_time * 0.04;

          vec2 toM = uv - u_mouse; float md = dot(toM, toM); float infl = exp(-md*3.0);
          vec2 swirl = vec2(-toM.y, toM.x);

          vec3 q = vec3(uv*1.7, t);
          vec2 warp = vec2(fbm(q), fbm(q + vec3(3.7,1.2,0.0)));
          vec3 r = vec3(uv*1.7 + 0.7*warp + (swirl*1.3 - toM*0.5)*infl, t*1.2);
          float n = fbm(r);
          float hgt = 0.5 + 0.5*n;

          vec3 paper = vec3(0.957, 0.945, 0.910);
          vec3 ink   = vec3(0.105, 0.100, 0.115);

          // soft tonal shading
          float shade = smoothstep(0.42, 0.95, hgt) * 0.55;
          vec3 col = mix(paper, ink, shade);

          // topographic contour lines (no derivatives needed)
          float band = fract(hgt * 9.0);
          float edge = min(band, 1.0 - band);
          float contour = 1.0 - smoothstep(0.015, 0.06, edge);
          col = mix(col, ink, contour * 0.35);

          // cursor: a darker ink pooling that deepens the field locally
          col = mix(col, ink, infl * 0.16);

          // faint paper grain
          float grain = fract(sin(dot(gl_FragCoord.xy, vec2(12.9898,78.233))) * 43758.5453);
          col += (grain - 0.5) * 0.012;

          gl_FragColor = vec4(col, 1.0);
        }
      `;

      const compile = (type: number, src: string) => {
        const s = gl.createShader(type)!;
        gl.shaderSource(s, src); gl.compileShader(s);
        if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) console.error('noise-fig:', gl.getShaderInfoLog(s));
        return s;
      };
      const prog = gl.createProgram()!;
      gl.attachShader(prog, compile(gl.VERTEX_SHADER, vert));
      gl.attachShader(prog, compile(gl.FRAGMENT_SHADER, frag));
      gl.linkProgram(prog); gl.useProgram(prog);

      const buf = gl.createBuffer();
      gl.bindBuffer(gl.ARRAY_BUFFER, buf);
      gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 3,-1, -1,3]), gl.STATIC_DRAW);
      const loc = gl.getAttribLocation(prog, 'p');
      gl.enableVertexAttribArray(loc);
      gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);

      const uRes = gl.getUniformLocation(prog, 'u_res');
      const uTime = gl.getUniformLocation(prog, 'u_time');
      const uMouse = gl.getUniformLocation(prog, 'u_mouse');

      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      let cw = 1, ch = 1;
      const resize = () => {
        const rect = canvas.getBoundingClientRect();
        cw = Math.max(1, Math.floor(rect.width * dpr));
        ch = Math.max(1, Math.floor(rect.height * dpr));
        canvas.width = cw; canvas.height = ch;
        gl.viewport(0, 0, cw, ch);
        gl.uniform2f(uRes, cw, ch);
      };
      const ro = new ResizeObserver(resize);
      ro.observe(canvas);
      resize();

      const target = { x: 0, y: 0 };
      const mouse = { x: 0, y: 0 };
      canvas.addEventListener('pointermove', (e) => {
        const rect = canvas.getBoundingClientRect();
        target.x = ((e.clientX - rect.left) * dpr - 0.5 * cw) / ch;
        target.y = (0.5 * ch - (e.clientY - rect.top) * dpr) / ch;
      }, { passive: true });
      canvas.addEventListener('pointerleave', () => { target.x = 0; target.y = 0; }, { passive: true });

      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const start = performance.now();
      let raf = 0;
      const render = (now: number) => {
        const t = reduce ? 8.0 : (now - start) / 1000;
        mouse.x += (target.x - mouse.x) * 0.07;
        mouse.y += (target.y - mouse.y) * 0.07;
        gl.uniform2f(uMouse, mouse.x, mouse.y);
        gl.uniform1f(uTime, t);
        gl.drawArrays(gl.TRIANGLES, 0, 3);
        if (!reduce) raf = requestAnimationFrame(render);
      };
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) cancelAnimationFrame(raf);
        else if (!reduce) raf = requestAnimationFrame(render);
      });
      render(start);
    }
  }

  // the install pill: a target dropdown (Agent/CLI/Web) + copy-to-clipboard for the shown command
  const pill = document.querySelector<HTMLElement>('.install-pill');
  if (pill) {
    const btn = pill.querySelector<HTMLButtonElement>('.install-copy-btn');
    const cmdEl = pill.querySelector<HTMLElement>('.install-cmd');
    const select = pill.querySelector<HTMLSelectElement>('.install-select');
    let resetTimer = 0;

    select?.addEventListener('change', () => {
      const cmd = select.value;
      if (btn && cmdEl) {
        btn.dataset.install = cmd;
        cmdEl.textContent = cmd;
        btn.setAttribute('aria-label', `Copy install command: ${cmd}`);
      }
      pill.classList.remove('copied');
      window.clearTimeout(resetTimer);
    });

    btn?.addEventListener('click', async () => {
      const cmd = btn.dataset.install ?? '';
      try {
        await navigator.clipboard.writeText(cmd);
      } catch {
        // older browsers / insecure context: fall back to a hidden textarea
        const ta = document.createElement('textarea');
        ta.value = cmd;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch {}
        ta.remove();
      }
      pill.classList.add('copied');
      window.clearTimeout(resetTimer);
      resetTimer = window.setTimeout(() => pill.classList.remove('copied'), 1600);
    });
  }
</script>
