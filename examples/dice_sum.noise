# Roll two dice and add them up. How often is the total exactly 7?
# 7 is the most likely total: there are 6 ways to make it (1+6, 2+5, ...) out of 36, so 1/6.
use rand;   # unif_int, iid

# Roll one fair die twice independently and add the rolls; ask how often the total is 7.
die   = unif_int(1, 6);
dice  = iid(die, 2);
total = vec::sum(dice);
Print("P(two dice sum to 7) =", P(total == 7))
