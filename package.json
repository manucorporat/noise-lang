{
  "name": "noise-lang-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.5",
  "description": "pnpm workspace root for the Noise language JS packages (the Rust crates live under crates/).",
  "scripts": {
    "build:core": "pnpm --filter @noiselang/core run build",
    "build:www": "pnpm --filter noise-www run build",
    "build": "pnpm run build:core && pnpm run build:www",
    "dev": "pnpm --filter noise-www run dev",
    "validate": "bash scripts/validate.sh",
    "changeset": "changeset",
    "ci:version": "changeset version && node scripts/sync-cargo-version.mjs",
    "ci:publish": "node scripts/publish-crates.mjs && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "typescript": "^5.6.0"
  }
}
