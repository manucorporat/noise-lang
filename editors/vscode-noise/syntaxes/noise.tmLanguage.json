{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Noise",
  "scopeName": "source.noise",
  "patterns": [
    { "include": "#shebang" },
    { "include": "#frontmatter" },
    { "include": "#templates" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#namespaces" },
    { "include": "#distributions" },
    { "include": "#queries" },
    { "include": "#builtins" },
    { "include": "#operators" }
  ],
  "repository": {
    "shebang": {
      "name": "comment.line.shebang.noise",
      "match": "\\A#!.*$"
    },
    "frontmatter": {
      "name": "meta.embedded.block.frontmatter.noise",
      "begin": "\\A(---)\\s*$",
      "end": "^(---)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.frontmatter.begin.noise" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.frontmatter.end.noise" }
      },
      "contentName": "source.yaml",
      "patterns": [{ "include": "source.yaml" }]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.noise",
          "match": "//.*$"
        },
        {
          "name": "comment.block.noise",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "templates": {
      "patterns": [
        { "include": "#template-fenced-md" },
        { "include": "#template-fenced-latex" },
        { "include": "#template-fenced" },
        { "include": "#template-inline" }
      ]
    },
    "template-hole": {
      "name": "meta.embedded.expression.noise",
      "begin": "\\$\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.noise" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.noise" }
      },
      "patterns": [{ "include": "$self" }]
    },
    "template-fenced-md": {
      "name": "meta.template.fenced.md.noise",
      "begin": "(```)\\s*(md|markdown)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.template.begin.noise" },
        "2": { "name": "fenced_code.block.language.noise" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.template.end.noise" }
      },
      "contentName": "text.html.markdown",
      "patterns": [
        { "include": "#template-hole" },
        { "include": "text.html.markdown" }
      ]
    },
    "template-fenced-latex": {
      "name": "meta.template.fenced.latex.noise",
      "begin": "(```)\\s*(latex|tex)\\s*$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.template.begin.noise" },
        "2": { "name": "fenced_code.block.language.noise" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.template.end.noise" }
      },
      "contentName": "text.tex.latex",
      "patterns": [
        { "include": "#template-hole" },
        { "include": "text.tex.latex" }
      ]
    },
    "template-fenced": {
      "name": "meta.template.fenced.noise",
      "begin": "(```)([^`\\n]*)$",
      "end": "^\\s*(```)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.template.begin.noise" },
        "2": { "name": "fenced_code.block.language.noise" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.template.end.noise" }
      },
      "contentName": "string.unquoted.template.noise",
      "patterns": [{ "include": "#template-hole" }]
    },
    "template-inline": {
      "name": "string.quoted.template.noise",
      "begin": "`",
      "end": "`",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.template.begin.noise" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.template.end.noise" }
      },
      "patterns": [{ "include": "#template-hole" }]
    },
    "strings": {
      "name": "string.quoted.double.noise",
      "begin": "\"",
      "end": "\"|$",
      "patterns": []
    },
    "numbers": {
      "name": "constant.numeric.noise",
      "match": "\\b(?:[0-9]+\\.?[0-9]*|\\.[0-9]+)(?:[eE][+-]?[0-9]+)?\\b"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.noise",
          "match": "\\b(use|if|else|for|in|continue)\\b"
        },
        {
          "name": "constant.language.boolean.noise",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "namespaces": {
      "match": "\\b(rand|vec|math|signal|builtin|engine|plot|stats|input)(::)",
      "captures": {
        "1": { "name": "entity.name.namespace.noise" },
        "2": { "name": "keyword.operator.namespace.noise" }
      }
    },
    "distributions": {
      "name": "support.function.distribution.noise",
      "match": "\\b(unif_int|unif|normal_int|normal_complex|normal|bernoulli|poisson|geometric|exponential_int|exponential|categorical|rotation|permutation|empirical|block_bootstrap)\\b"
    },
    "queries": {
      "name": "support.function.builtin.noise",
      "match": "\\b(P|Q|E|Var|Print|Len)\\b"
    },
    "builtins": {
      "name": "support.function.noise",
      "match": "\\b(pi|e|i|j|sqrt|exp|abs|arg|conj|re|im|floor|ceil|round|log10|log|sin|cos|atan|sign|gcd|modpow|sum|count_duplicates|count|any|all|max|min|mean|dot|vdot|normsq|norm|transpose|adjoint|normalize|has_duplicates|mse|ones|zeros|iota|outer|quantize|prod|cumsum|cumprod|cummax|cummin|sine|cosine|sample|noise_white_complex|noise_white|noise_brown|noise_pink|noise_ou|set_precision|set_resolution)\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.sample.noise",
          "match": "~"
        },
        {
          "name": "keyword.operator.noise",
          "match": "\\*\\*|==|!=|<=|>=|&&|\\|\\||\\.\\.|[-+*/<>=!|@]"
        }
      ]
    }
  }
}
