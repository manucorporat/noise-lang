{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Noise",
  "scopeName": "source.noise",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#namespaces" },
    { "include": "#distributions" },
    { "include": "#queries" },
    { "include": "#builtins" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.noise",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.noise",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.noise",
      "begin": "\"",
      "end": "\"|$",
      "patterns": []
    },
    "numbers": {
      "name": "constant.numeric.noise",
      "match": "\\b(?:[0-9]+\\.?[0-9]*|\\.[0-9]+)\\b"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.noise",
          "match": "\\b(use|if|else|for|in|continue)\\b"
        },
        {
          "name": "constant.language.boolean.noise",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "namespaces": {
      "match": "\\b(rand|vec|math|signal|builtin)(::)",
      "captures": {
        "1": { "name": "entity.name.namespace.noise" },
        "2": { "name": "keyword.operator.namespace.noise" }
      }
    },
    "distributions": {
      "name": "support.function.distribution.noise",
      "match": "\\b(unif_int|unif|normal_int|normal_complex|normal|bernoulli|poisson|geometric|exponential_int|exponential|categorical|rotation|permutation)\\b"
    },
    "queries": {
      "name": "support.function.builtin.noise",
      "match": "\\b(P|Q|E|Var|Print|Len)\\b"
    },
    "builtins": {
      "name": "support.function.noise",
      "match": "\\b(pi|e|i|j|sqrt|exp|abs|arg|conj|re|im|floor|ceil|round|log10|log|sin|cos|atan|sign|gcd|modpow|sum|count|any|all|max|min|mean|dot|vdot|normsq|norm|vadd|vsub|vsign|matvec|transpose|adjoint|normalize|outer|quantize|has_duplicate|mse|ones|zeros|iota|scale|sine|cosine|noise_white|sample)\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.sample.noise",
          "match": "~"
        },
        {
          "name": "keyword.operator.noise",
          "match": "\\*\\*|==|!=|<=|>=|&&|\\|\\||\\.\\.|[-+*/<>=!|]"
        }
      ]
    }
  }
}
